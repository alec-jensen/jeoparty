---
import '@/styles/global.css';
import { db, schema } from '@/lib/db';
import { eq, desc } from 'drizzle-orm';

if (!Astro.locals.host) return Astro.redirect('/');
const boards = await db.select({ id: schema.boards.id, title: schema.boards.title, updatedAt: schema.boards.updatedAt })
  .from(schema.boards)
  .where(eq(schema.boards.hostId, Astro.locals.host.hostId))
  .orderBy(desc(schema.boards.updatedAt));
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Dashboard — Jeoparty</title>
  <style is:global>
    html, body { height: 100%; overflow: hidden; margin: 0; }
    body { display: flex; flex-direction: column; background: var(--bg); color: var(--ink); font-family: 'Space Grotesk', sans-serif; }

    /* ── Header (Cohesive with Editor) ─────────────────────────── */
    #hdr {
      display: flex; align-items: center; height: 56px;
      padding: 0 20px; gap: 16px; flex-shrink: 0;
      background: var(--bg2); border-bottom: 1px solid var(--line);
    }
    #hdr-left  { display: flex; align-items: center; gap: 12px; }
    #hdr-mid   { display: flex; align-items: center; gap: 10px; flex: 1; justify-content: center; }
    #hdr-right { display: flex; align-items: center; gap: 8px; }

    .brand { font-family: 'Anton', sans-serif; font-size: 22px; color: var(--gold); letter-spacing: .04em; line-height: 1; text-decoration: none; }
    .editor-badge { font-size: 10px; color: var(--dim); letter-spacing: .22em; padding: 3px 7px; background: var(--bg3); border-radius: 4px; }

    .back-btn {
      display: flex; align-items: center; gap: 5px;
      padding: 6px 11px; border-radius: 8px; cursor: pointer;
      border: 1.5px solid var(--line); background: transparent;
      color: var(--dim); font-size: 11px; letter-spacing: 0.12em; font-weight: 700;
      transition: border-color .15s, color .15s; text-decoration: none;
      box-shadow: none;
    }
    .back-btn:hover { border-color: var(--line2); color: var(--ink); box-shadow: none; transform: none; }

    .ghost-btn {
      padding: 7px 14px; border-radius: 8px;
      border: 1.5px solid var(--line); background: transparent;
      color: var(--ink); font-size: 12px; font-weight: 600; letter-spacing: .12em;
      cursor: pointer; transition: border-color .15s; box-shadow: none;
      text-decoration: none; display: inline-block;
    }
    .ghost-btn:hover { border-color: var(--line2); box-shadow: none; transform: none; }

    .start-btn {
      display: flex; align-items: center; gap: 7px;
      padding: 8px 16px; border-radius: 8px;
      background: var(--gold); border: none;
      color: var(--bg); font-family: 'Anton', sans-serif;
      font-size: 13px; letter-spacing: .1em; cursor: pointer;
      transition: filter .15s; box-shadow: none;
    }
    .start-btn:hover { filter: brightness(1.1); box-shadow: none; transform: none; }

    /* ── Dashboard Grid ────────────────────────────────────────── */
    #main { flex: 1; overflow-y: auto; padding: 30px 20px; }
    .page-title { font-family: 'Anton', sans-serif; font-size: 32px; letter-spacing: .02em; margin-bottom: 24px; color: var(--ink); }

    .board-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
    }

    .board-card {
      background: var(--bg2); border: 1.5px solid var(--line);
      border-radius: 16px; padding: 24px;
      display: flex; flex-direction: column;
      transition: border-color .15s, transform .15s; position: relative;
    }
    .board-card:hover { border-color: var(--line2); transform: translateY(-2px); }

    .board-card-title { font-family: 'Anton', sans-serif; font-size: 22px; color: var(--gold); letter-spacing: .03em; margin: 0; line-height: 1.2; }
    .board-card-date { font-size: 10px; color: var(--dim); letter-spacing: .1em; font-weight: 700; margin-top: 6px; }

    .board-card-actions { display: flex; gap: 10px; margin-top: 28px; }
    .board-card-del {
      position: absolute; top: 16px; right: 16px;
      width: 24px; height: 24px; border: none; background: transparent;
      color: var(--dim); font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: color .15s; box-shadow: none;
    }
    .board-card-del:hover { color: var(--red); box-shadow: none; transform: none; }

    /* ── Modal ─────────────────────────────────────────────────── */
    #startModal {
      position: fixed; inset: 0; background: rgba(0,0,0,.8);
      z-index: 100; display: none; align-items: center; justify-content: center;
      backdrop-filter: blur(4px);
    }
    .modal-content {
      background: var(--bg2); border: 1.5px solid var(--line);
      border-radius: 16px; padding: 30px; width: 100%; max-width: 420px;
      display: flex; flex-direction: column; gap: 20px;
    }
    .modal-title { font-family: 'Anton', sans-serif; font-size: 24px; color: var(--gold); letter-spacing: .04em; }
    .field-lbl { font-size: 10px; color: var(--dim); letter-spacing: .22em; font-weight: 600; margin-bottom: 6px; }

    .modal-actions { display: flex; gap: 10px; margin-top: 10px; }

    /* Toggle from editor */
    .toggle {
      width: 40px; height: 22px; border-radius: 999px; background: var(--bg3);
      border: 1px solid var(--line2); cursor: pointer; position: relative;
      transition: background .2s;
    }
    .toggle::after {
      content: ''; position: absolute; top: 3px; left: 3px;
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--dim); transition: transform .2s, background .2s;
    }
    .toggle.on { background: #3A6FDF; border-color: #5B8DEF; }
    .toggle.on::after { transform: translateX(18px); background: #fff; }

    input[type="number"] {
      background: var(--bg); border: 1.5px solid var(--line);
      border-radius: 8px; color: var(--ink); padding: 8px 12px;
      font-family: inherit; font-size: 14px; outline: none;
    }
    input[type="number"]:focus { border-color: var(--gold); }
  </style>
</head>
<body>

  <!-- ── Header ──────────────────────────────────────────────────────────── -->
  <div id="hdr">
    <div id="hdr-left">
      <a href="/" class="brand">JEOPARTY</a>
      <span class="editor-badge">DASHBOARD</span>
    </div>
    <div id="hdr-mid">
      <span style="font-size:11px; color:var(--dim); letter-spacing:.1em; font-weight:700;">{Astro.locals.host.email.toUpperCase()}</span>
    </div>
    <div id="hdr-right">
      <button id="logout" class="back-btn">LOG OUT</button>
      <a href="/boards/new" class="start-btn">+ NEW BOARD</a>
    </div>
  </div>

  <!-- ── Main ────────────────────────────────────────────────────────────── -->
  <main id="main">
    <div class="page-title">YOUR BOARDS</div>

    <div class="board-grid">
      {boards.length === 0 && (
        <div style="grid-column: 1 / -1; text-align:center; padding:60px 20px; background:var(--bg2); border:1.5px dashed var(--line); border-radius:16px;">
          <p class="muted" style="font-size:16px;">No boards yet. Create one to get started!</p>
          <a href="/boards/new" class="start-btn" style="display:inline-flex; margin-top:20px;">+ CREATE YOUR FIRST BOARD</a>
        </div>
      )}

      {boards.map((board) => (
        <div class="board-card" data-board-id={board.id}>
          <button class="board-card-del" onclick={`deleteBoard(${board.id})`} title="Delete Board">×</button>
          <div>
            <h3 class="board-card-title">{board.title || 'UNTITLED BOARD'}</h3>
            <p class="board-card-date">UPDATED: {board.updatedAt ? new Date(board.updatedAt).toLocaleString().toUpperCase() : '—'}</p>
          </div>
          <div class="board-card-actions">
            <a href={`/boards/${board.id}`} class="ghost-btn" style="flex:1; text-align:center;">EDIT</a>
            <button class="start-btn start-trigger" data-board-id={board.id} style="flex:1.5;">▶ START GAME</button>
          </div>
        </div>
      ))}
    </div>
  </main>

  <!-- ── Start game modal ────────────────────────────────────────────────── -->
  <div id="startModal">
    <div class="modal-content">
      <div class="modal-title">START GAME</div>
      
      <div style="display:flex; align-items:center; justify-content:space-between;">
        <span class="field-lbl" style="margin-bottom:0;">TEAM MODE</span>
        <button id="teamModeToggle" class="toggle"></button>
      </div>

      <div id="teamCountWrap" style="display:none;">
        <div class="field-lbl">NUMBER OF TEAMS (2–6)</div>
        <input id="numTeams" type="number" min="2" max="6" value="2" style="width:100%;" />
      </div>

      <div class="modal-actions">
        <button id="confirmStart" class="start-btn" style="flex:1;">START!</button>
        <button id="cancelStart" class="ghost-btn">CANCEL</button>
      </div>
    </div>
  </div>

  <script is:inline>
    // @ts-nocheck
    let pendingBoardId = null;
    const modal = document.getElementById('startModal');
    const teamToggle = document.getElementById('teamModeToggle');
    const teamCountWrap = document.getElementById('teamCountWrap');

    teamToggle.addEventListener('click', () => {
      teamToggle.classList.toggle('on');
      teamCountWrap.style.display = teamToggle.classList.contains('on') ? 'block' : 'none';
    });

    for (const btn of document.querySelectorAll('.start-trigger')) {
      btn.addEventListener('click', () => {
        pendingBoardId = Number(btn.dataset.boardId);
        modal.style.display = 'flex';
      });
    }

    document.getElementById('cancelStart').addEventListener('click', () => { modal.style.display = 'none'; });
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

    document.getElementById('confirmStart').addEventListener('click', async () => {
      const teamMode = teamToggle.classList.contains('on');
      const numTeams = teamMode ? Number(document.getElementById('numTeams').value) : 0;
      const res = await fetch('/api/games/create', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ boardId: pendingBoardId, teamMode, numTeams }),
      });
      if (!res.ok) return alert('Could not create game');
      const json = await res.json();
      location.href = `/game/${json.id}`;
    });

    document.getElementById('logout').addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      location.href = '/';
    });

    async function deleteBoard(id) {
      if (!confirm('Are you sure you want to delete this board? This cannot be undone.')) return;
      const res = await fetch(`/api/boards/${id}`, { method: 'DELETE' });
      if (res.ok) {
        document.querySelector(`.board-card[data-board-id="${id}"]`)?.remove();
        // If no more boards, just reload to show empty state
        if (document.querySelectorAll('.board-card').length === 0) location.reload();
      } else {
        alert('Failed to delete board');
      }
    }
    window.deleteBoard = deleteBoard;
  </script>
</body>
</html>
