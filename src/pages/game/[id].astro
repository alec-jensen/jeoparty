---
import '@/styles/global.css';
import QRCode from 'qrcode';
import { db, schema } from '@/lib/db';
import { getPublicOrigin } from '@/lib/requestOrigin';
import { eq } from 'drizzle-orm';

const gameId = String(Astro.params.id).toUpperCase();
const gameRows = await db.select({ id: schema.games.id, status: schema.games.status })
  .from(schema.games).where(eq(schema.games.id, gameId));
if (!gameRows.length) return Astro.redirect('/');

const publicOrigin = getPublicOrigin(Astro.request, Astro.url);
const publicHost = new URL(publicOrigin).host;
const joinUrl = `${publicOrigin}/join?code=${gameId}`;
const qrSvg = await QRCode.toString(joinUrl, { type: 'svg', color: { dark: '#FFC83D', light: '#0E0B22' }, margin: 1 });
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Jeoparty — {gameId}</title>
  <style is:global>
    html, body { height: 100%; overflow: hidden; background: #0E0B22; margin: 0; }
    #scale-root { transform-origin: top left; }
    #conn-status { position: absolute; bottom: 10px; right: 10px; font-size: 0.7rem; color: #333; z-index: 100; opacity: 0.3; }

    /* ── Audio gate (autoplay unlock) ─────────────────────────────────── */
    #audioGate {
      position: absolute; inset: 0;
      background: rgba(14,11,34,0.95);
      display: flex; align-items: center; justify-content: center;
      z-index: 200; cursor: pointer;
      backdrop-filter: blur(8px);
    }
    #audioGate.hidden { display: none; }
    #audioGate .gate-inner { text-align: center; animation: jp-pulse 2s ease-in-out infinite; }
    #audioGate .gate-title {
      font-family: 'Anton', sans-serif;
      font-size: 6rem; color: var(--gold);
      letter-spacing: 0.04em; line-height: 1;
      text-shadow: 0 0 40px rgba(255,200,61,0.4);
    }
    #audioGate .gate-sub {
      font-size: 1.5rem; color: var(--dim);
      margin-top: 1rem; letter-spacing: 0.04em;
    }
    @keyframes jp-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }

    /* ── Lobby/game crossfade ─────────────────────────────────────────── */
    #lobbyScreen, #gameScreen {
      position: absolute; inset: 0;
      opacity: 1;
      transition: opacity 0.6s ease;
    }
    #lobbyScreen.crossfade-out, #gameScreen.crossfade-out {
      opacity: 0;
      pointer-events: none;
    }

    /* ── JEOPARTY 3D intro (full 23-second sequence) ────────────────────── */
    #jpFlash {
      position: absolute; inset: 0;
      overflow: hidden;
      perspective: 1400px;
      perspective-origin: 50% 50%;
      z-index: 150;
      pointer-events: none;
      background:
        radial-gradient(ellipse at 50% 50%, rgba(31,25,71,0.6) 0%, rgba(14,11,34,1) 70%),
        #0E0B22;
      transition: opacity 0.6s ease;
    }
    #jpFlash.hidden { display: none; }
    /* Subtle starfield via tiny dots */
    #jpFlash .jp-stars {
      position: absolute; inset: 0;
      background-image:
        radial-gradient(1.5px 1.5px at 12% 28%, #FFE39A 50%, transparent 51%),
        radial-gradient(1px 1px at 78% 14%, #F4EEFF 50%, transparent 51%),
        radial-gradient(2px 2px at 33% 72%, #FFC83D 50%, transparent 51%),
        radial-gradient(1px 1px at 90% 60%, #F4EEFF 50%, transparent 51%),
        radial-gradient(1.5px 1.5px at 56% 88%, #FFE39A 50%, transparent 51%),
        radial-gradient(1px 1px at 22% 56%, #F4EEFF 50%, transparent 51%),
        radial-gradient(1.5px 1.5px at 67% 32%, #FFC83D 50%, transparent 51%),
        radial-gradient(1px 1px at 44% 12%, #F4EEFF 50%, transparent 51%),
        radial-gradient(1.5px 1.5px at 86% 84%, #FFE39A 50%, transparent 51%),
        radial-gradient(1px 1px at 8% 92%, #F4EEFF 50%, transparent 51%);
      opacity: 0.7;
      animation: jp-stars-pan 23s linear forwards;
    }
    @keyframes jp-stars-pan {
      0%   { background-position: 0% 0%; opacity: 0; }
      8%   { opacity: 0.7; }
      92%  { opacity: 0.7; }
      100% { background-position: -40% 12%; opacity: 0; }
    }
    /* ── Player intro card (slides through middle of intro) ────────────── */
    .player-intro-card {
      position: absolute;
      top: 62%;
      left: 50%;
      display: flex; flex-direction: column; align-items: center; gap: 1.2rem;
      z-index: 3;
      pointer-events: none;
      will-change: transform, opacity;
    }
    .player-intro-card .pi-eyebrow {
      font-family: 'Anton', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.32em;
      color: var(--dim);
      text-transform: uppercase;
    }
    .player-intro-card .pi-avatar {
      width: 220px; height: 220px;
      border-radius: 36px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Anton', sans-serif;
      font-size: 9rem; line-height: 1;
      color: #0E0B22;
      font-weight: 800;
      box-shadow:
        0 18px 0 rgba(0,0,0,0.5),
        0 30px 80px rgba(0,0,0,0.5),
        inset 0 -10px 24px rgba(0,0,0,0.2),
        inset 0 10px 24px rgba(255,255,255,0.22);
    }
    .player-intro-card .pi-name {
      font-family: 'Anton', sans-serif;
      font-size: 7rem;
      color: var(--ink);
      letter-spacing: 0.04em;
      line-height: 0.95;
      text-shadow: 0 0 60px rgba(255,255,255,0.35), 0 6px 0 rgba(0,0,0,0.4);
      text-transform: uppercase;
    }
    .player-intro-card .pi-score {
      font-family: 'Anton', sans-serif;
      font-size: 3rem;
      letter-spacing: 0.06em;
      text-shadow: 0 0 30px currentColor;
    }
    /* Entry from right, exit left */
    @keyframes player-intro-slide {
      0%   { opacity: 0; transform: translate(160%, -50%) rotate(6deg) scale(0.85); }
      15%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1.04); }
      25%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      80%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      100% { opacity: 0; transform: translate(-260%, -50%) rotate(-6deg) scale(0.85); }
    }
    /* Entry from left, exit right */
    @keyframes player-intro-from-left {
      0%   { opacity: 0; transform: translate(-260%, -50%) rotate(-6deg) scale(0.85); }
      15%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1.04); }
      25%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      80%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      100% { opacity: 0; transform: translate(160%, -50%) rotate(6deg) scale(0.85); }
    }
    /* Entry from bottom, exit top */
    @keyframes player-intro-from-bottom {
      0%   { opacity: 0; transform: translate(-50%, 150%) rotate(4deg) scale(0.85); }
      15%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1.04); }
      25%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      80%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      100% { opacity: 0; transform: translate(-50%, -250%) rotate(-4deg) scale(0.85); }
    }
    /* Entry from top, exit bottom */
    @keyframes player-intro-from-top {
      0%   { opacity: 0; transform: translate(-50%, -250%) rotate(-4deg) scale(0.85); }
      15%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1.04); }
      25%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      80%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg) scale(1); }
      100% { opacity: 0; transform: translate(-50%, 150%) rotate(4deg) scale(0.85); }
    }

    /* Compact card sizes for multi-column slots */
    .player-intro-card.pi-sm .pi-avatar { width: 150px; height: 150px; border-radius: 24px; font-size: 6rem; }
    .player-intro-card.pi-sm .pi-name   { font-size: 4.5rem; }
    .player-intro-card.pi-sm .pi-score  { font-size: 2rem; }
    .player-intro-card.pi-sm .pi-eyebrow { font-size: 1.1rem; }

    .player-intro-card.pi-xs .pi-avatar { width: 110px; height: 110px; border-radius: 18px; font-size: 4.5rem; }
    .player-intro-card.pi-xs .pi-name   { font-size: 3.2rem; }
    .player-intro-card.pi-xs .pi-score  { font-size: 1.5rem; }
    .player-intro-card.pi-xs .pi-eyebrow { font-size: 0.9rem; }

    /* ── Board fill animation ─────────────────────────────────────────── */
    @keyframes cell-fill-in {
      0%   { opacity: 0; transform: scale(0.5) rotateX(-90deg); }
      60%  { opacity: 1; transform: scale(1.04) rotateX(0deg); }
      100% { opacity: 1; transform: scale(1) rotateX(0deg); }
    }
    .presenter-board-grid.filling .presenter-cat-header,
    .presenter-board-grid.filling .presenter-q-cell {
      animation: cell-fill-in 0.45s cubic-bezier(0.2, 0.7, 0.3, 1.2) backwards;
      transform-style: preserve-3d;
      backface-visibility: visible;
    }

    /* ── Game over reveal animations ─────────────────────────────────── */
    @keyframes go-slide-in {
      from { opacity: 0; transform: translateY(-36px) scale(0.9); }
      to   { opacity: 1; transform: translateY(0)    scale(1);   }
    }
    @keyframes go-winner-dance {
      0%   { transform: scale(1)    rotate(0deg);   }
      12%  { transform: scale(1.07) rotate(-3deg);  }
      25%  { transform: scale(1.09) rotate(3deg);   }
      37%  { transform: scale(1.06) rotate(-2deg);  }
      50%  { transform: scale(1.09) rotate(2.5deg); }
      62%  { transform: scale(1.06) rotate(-1.5deg);}
      75%  { transform: scale(1.08) rotate(1.5deg); }
      87%  { transform: scale(1.05) rotate(-0.5deg);}
      100% { transform: scale(1)    rotate(0deg);   }
    }
    @keyframes go-winner-glow {
      0%, 100% { box-shadow: 0 0 24px rgba(255,200,61,0.25), 0 8px 0 #B88A1F; }
      50%       { box-shadow: 0 0 70px rgba(255,200,61,0.65), 0 8px 0 #B88A1F; }
    }
  </style>
</head>
<body>
  <div id="scale-root" class="presenter-root">

    <!-- Lobby screen (before game starts) -->
    <div id="lobbyScreen" style="height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2rem;">
      <div id="lobbyLogoContainer" style="position:relative; width:80vw; max-width:1100px; height:220px;" aria-hidden="true"></div>
      <div class="join-code">{gameId}</div>
      <p style="font-family:'Anton',sans-serif; font-size:1.6rem; color:var(--muted);">Go to <strong style="color:var(--text);">{publicHost}/join</strong> and enter the code above</p>
      <div set:html={qrSvg} style="width:220px; height:220px;" />
      <div id="playerList" style="display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; max-width:1200px; margin-top:0.5rem;"></div>
    </div>

    <!-- Active game screen -->
    <div id="gameScreen" class="hidden" style="height:100%; display:flex; flex-direction:column;">
      <!-- Top bar -->
      <div style="display:flex; align-items:center; justify-content:space-between; padding:32px 56px 24px; flex-shrink:0;">
        <div style="display:flex; align-items:center; gap:18px;">
          <div id="gameLogoContainer" style="position:relative; width:300px; height:68px;" aria-hidden="true"></div>
          <span style="font-size:18px; color:var(--dim); letter-spacing:0.18em;">ROOM · {gameId}</span>
        </div>
        <div style="display:flex; align-items:center; gap:28px;">
          <div id="roundPill" style="padding:10px 18px; border-radius:999px; border:1.5px solid var(--gold); color:var(--gold); font-family:'Anton',sans-serif; letter-spacing:0.12em; font-size:16px;"></div>
          <div id="cluesPill" style="padding:10px 18px; border-radius:999px; border:1.5px solid var(--line); color:var(--dim); font-family:'Anton',sans-serif; letter-spacing:0.12em; font-size:16px;"></div>
        </div>
      </div>
      <!-- Board -->
      <div style="flex:1; padding:0 56px 24px; display:flex; flex-direction:column; min-height:0;">
        <div id="presenterBoard" class="presenter-board-grid" style="flex:1; min-height:0;"></div>
      </div>
      <!-- Scoreboard -->
      <div id="presenterScores" style="padding:20px 56px 32px; display:grid; gap:14px; flex-shrink:0;"></div>
    </div>

    <!-- Question overlay -->
    <div id="questionOverlay" class="question-overlay hidden">
      <div class="q-category" id="qCategory"></div>
      <div class="q-text" id="qText"></div>
      <div id="buzzBanner" class="buzz-banner hidden">
        <span class="buzz-dot"></span>
        <span id="buzzName"></span>
      </div>
    </div>

    <!-- Round advance notification -->
    <div id="roundNotif" class="hidden" style="position:absolute;inset:0;background:rgba(10,5,30,0.92);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:50;animation:slide-up .3s ease;">
      <div style="font-family:'Anton',sans-serif;font-size:3rem;color:var(--muted);">Next Up</div>
      <div id="roundNotifTitle" style="font-family:'Anton',sans-serif;font-size:6rem;font-weight:700;color:var(--accent);"></div>
    </div>

    <!-- Audio unlock gate -->
    <div id="audioGate" class="hidden">
      <div class="gate-inner">
        <div class="gate-title">TAP TO START</div>
        <div class="gate-sub">Click anywhere to enable sound</div>
      </div>
    </div>

    <!-- JEOPARTY flash overlay (intro → board transition) -->
    <div id="jpFlash" class="hidden"></div>
  </div>

  <script>
    import { createIntro, createLogoIdle } from '@/scripts/intro-3d';
    // Expose to the inline script below so it can mount the Three.js intro
    (window as any).__createJeopartyIntro = (container: HTMLElement) =>
      createIntro(container, '/fonts/Anton.typeface.json');

    const fontUrl = '/fonts/Anton.typeface.json';

    // Lobby hero logo (large, centered)
    const lobbyEl = document.getElementById('lobbyLogoContainer');
    let lobbyLogoCtrl: { dispose(): void } | null = null;
    if (lobbyEl) createLogoIdle(lobbyEl, fontUrl, { canvasExpand: 1.75 }).then(c => { lobbyLogoCtrl = c; }).catch(() => {});
    (window as any).__disposeLobbyLogo = () => { lobbyLogoCtrl?.dispose(); lobbyLogoCtrl = null; };

    // Game header logo (small, persistent)
    const gameLogoEl = document.getElementById('gameLogoContainer');
    if (gameLogoEl) createLogoIdle(gameLogoEl, fontUrl).catch(() => {});
  </script>

  <script is:inline define:vars={{ gameId }}>
    // @ts-nocheck
    /* ── Scaling ───────────────────────────────────────────────────────────── */
    function scale() {
      const root = document.getElementById('scale-root');
      if (!root) return;
      const tw = 1920; const th = 1080;
      const s = Math.min(window.innerWidth / tw, window.innerHeight / th) || 1;
      root.style.width = tw + 'px';
      root.style.height = th + 'px';
      root.style.transform = `scale(${s})`;
      root.style.position = 'absolute';
      root.style.left = '50%';
      root.style.top = '50%';
      root.style.marginLeft = `-${(tw * s) / 2}px`;
      root.style.marginTop = `-${(th * s) / 2}px`;
      root.style.transformOrigin = 'top left';
    }
    scale();
    window.addEventListener('resize', scale);

    /* ── State ─────────────────────────────────────────────────────────────── */
    let gameState = { board: null, usedQuestions: new Set(), scores: [], teams: [], currentPicker: null, currentRound: 0, totalRounds: 1, teamMode: false, status: 'lobby' };
    let offset = 0;
    const PLAYER_COLORS = ['#FFC83D', '#FF3D8E', '#5EEBC1', '#7C5CFF', '#FF8A3D', '#5BA9FF'];
    const AV_COLORS = ['#FF3D8E','#FFC83D','#5EEBC1','#7C5CFF','#FF8A3D','#5BA9FF'];
    const _SQUIG = 'polygon(50.0% 2.0%,53.1% 2.8%,55.9% 4.9%,58.4% 7.8%,60.5% 10.9%,62.4% 13.4%,64.5% 14.9%,67.1% 15.3%,70.2% 14.9%,73.9% 14.2%,77.7% 13.9%,81.2% 14.4%,83.9% 16.1%,85.6% 18.8%,86.1% 22.3%,85.8% 26.1%,85.1% 29.7%,84.7% 32.9%,85.1% 35.5%,86.6% 37.6%,89.1% 39.5%,92.2% 41.6%,95.1% 44.1%,97.2% 46.9%,98.0% 50.0%,97.2% 53.1%,95.1% 55.9%,92.2% 58.4%,89.1% 60.5%,86.6% 62.4%,85.1% 64.5%,84.7% 67.1%,85.1% 70.2%,85.8% 73.9%,86.1% 77.7%,85.6% 81.2%,83.9% 83.9%,81.2% 85.6%,77.7% 86.1%,73.9% 85.8%,70.2% 85.1%,67.1% 84.7%,64.5% 85.1%,62.4% 86.6%,60.5% 89.1%,58.4% 92.2%,55.9% 95.1%,53.1% 97.2%,50.0% 98.0%,46.9% 97.2%,44.1% 95.1%,41.6% 92.2%,39.5% 89.1%,37.6% 86.6%,35.5% 85.1%,32.9% 84.7%,29.8% 85.1%,26.1% 85.8%,22.3% 86.1%,18.8% 85.6%,16.1% 83.9%,14.4% 81.2%,13.9% 77.7%,14.2% 73.9%,14.9% 70.3%,15.3% 67.1%,14.9% 64.5%,13.4% 62.4%,10.9% 60.5%,7.8% 58.4%,4.9% 55.9%,2.8% 53.1%,2.0% 50.0%,2.8% 46.9%,4.9% 44.1%,7.8% 41.6%,10.9% 39.5%,13.4% 37.6%,14.9% 35.5%,15.3% 32.9%,14.9% 29.7%,14.2% 26.1%,13.9% 22.3%,14.4% 18.8%,16.1% 16.1%,18.8% 14.4%,22.3% 13.9%,26.1% 14.2%,29.7% 14.9%,32.9% 15.3%,35.5% 14.9%,37.6% 13.4%,39.5% 10.9%,41.6% 7.8%,44.1% 4.9%,46.9% 2.8%)';
    const AV_OUTERS = [
      { r: '50%', cp: ''     },
      { r: '28%', cp: ''     },
      { r: '',    cp: _SQUIG },
    ];
    const AV_INNERS = ['✦','◆','●','▲','◐','■'];
    const NUM_C = 6, NUM_O = 3, NUM_I = 6;
    function avFromDb(color, shape) {
      const c = (color ?? 0) % NUM_C;
      const s = shape ?? 0;
      const outer = AV_OUTERS[Math.floor(s / NUM_I) % NUM_O];
      return { bg: AV_COLORS[c], radius: outer.r, clipPath: outer.cp, glyph: AV_INNERS[s % NUM_I] };
    }
    function applyAvEl(el, color, shape) {
      const av = avFromDb(color, shape);
      el.style.background   = av.bg;
      el.style.borderRadius = av.radius;
      el.style.clipPath     = av.clipPath;
      el.textContent        = av.glyph;
    }
    let playerColorMap = {};

    /* ── Audio ─────────────────────────────────────────────────────────────── */
    const SOUNDS = {
      theme:       { src: '/sounds/theme_song.mp3',       loop: true,  volume: 0.55 },
      intro:       { src: '/sounds/this_is_jeopardy.mp3', loop: false, volume: 0.9 },
      boardFill:   { src: '/sounds/board_fill.mp3',       loop: false, volume: 1.0 },
      correct:     { src: '/sounds/correct.mp3',          loop: false, volume: 0.8 },
      incorrect:   { src: '/sounds/incorrect.mp3',        loop: false, volume: 0.8 },
      dailyDouble: { src: '/sounds/daily_double.mp3',     loop: false, volume: 0.85 },
      think:       { src: '/sounds/think_music.mp3',      loop: true,  volume: 0.55 },
      timesUp:     { src: '/sounds/times_up.mp3',         loop: false, volume: 0.8 },
      roundOver:   { src: '/sounds/round_over.mp3',       loop: false, volume: 0.8 },
    };
    const audio = {};
    for (const [k, cfg] of Object.entries(SOUNDS)) {
      const a = new Audio(cfg.src);
      a.preload = 'auto';
      a.loop = cfg.loop;
      a.volume = cfg.volume;
      audio[k] = a;
    }

    /* ── Background music playlist ─────────────────────────────────────────── */
    const BG_SRCS = [
      '/sounds/bg_music/1.mp3',
      '/sounds/bg_music/2.mp3',
      '/sounds/bg_music/3.mp3',
      '/sounds/bg_music/4.mp3',
      '/sounds/bg_music/5.mp3',
      '/sounds/bg_music/6.mp3',
    ];
    const BG_VOL = 0.3;
    const bgPlaylist = (() => {
      const els = BG_SRCS.map(src => { const a = new Audio(src); a.preload = 'auto'; a.volume = BG_VOL; return a; });
      let curIdx = -1;
      let running = false;
      let fadeTimer = null;
      function clearFade() { if (fadeTimer) { clearInterval(fadeTimer); fadeTimer = null; } }
      function nextTrack() {
        if (!running) return;
        let idx;
        do { idx = Math.floor(Math.random() * els.length); } while (idx === curIdx && els.length > 1);
        curIdx = idx;
        const a = els[idx];
        a.currentTime = 0;
        a.volume = BG_VOL;
        a.onended = () => { if (running) nextTrack(); };
        a.play().catch(() => {});
      }
      return {
        prime: () => Promise.allSettled(els.map(a => { const w = a.muted; a.muted = true; return a.play().then(() => { a.pause(); a.currentTime = 0; a.muted = w; }).catch(() => { a.muted = w; }); })),
        isPlaying: () => curIdx >= 0 && !els[curIdx]?.paused,
        stop() {
          clearFade(); running = false; curIdx = -1;
          els.forEach(a => { try { a.pause(); a.currentTime = 0; a.volume = BG_VOL; } catch {} });
        },
        fadeOut(ms = 1200) {
          clearFade();
          if (curIdx < 0) return;
          const a = els[curIdx];
          if (!a || a.paused) return;
          const start = a.volume; let i = 0; const steps = 24;
          fadeTimer = setInterval(() => {
            i++; a.volume = Math.max(0, start * (1 - i / steps));
            if (i >= steps) { clearFade(); a.pause(); a.volume = BG_VOL; }
          }, ms / steps);
        },
        fadeIn(ms = 800) {
          if (!audioEnabled) return;
          clearFade(); running = true;
          // Resume the paused track if there is one, otherwise start fresh
          const cur = curIdx >= 0 ? els[curIdx] : null;
          let target;
          if (cur && cur.paused) {
            cur.volume = 0; cur.play().catch(() => {}); target = cur;
          } else {
            let idx; do { idx = Math.floor(Math.random() * els.length); } while (idx === curIdx && els.length > 1);
            curIdx = idx; target = els[idx];
            target.currentTime = 0; target.volume = 0;
            target.onended = () => { if (running) nextTrack(); };
            target.play().catch(() => {});
          }
          let i = 0; const steps = 20;
          fadeTimer = setInterval(() => {
            i++; target.volume = Math.min(BG_VOL, BG_VOL * (i / steps));
            if (i >= steps) clearFade();
          }, ms / steps);
        },
      };
    })();

    let audioEnabled = false;
    let soundEffectsEnabled = true; // updated from GAME_START message
    let awaitingIntro = false;
    let crossfading = false;
    let pendingBoardReveal = false;
    let introTimeouts = [];
    let introController = null; // Three.js intro controller, lazy-loaded

    function playSound(name) {
      if (!audioEnabled || !soundEffectsEnabled) return;
      const a = audio[name]; if (!a) return;
      try { a.currentTime = 0; a.volume = SOUNDS[name].volume; a.play().catch(() => {}); } catch {}
    }
    function stopSound(name) {
      const a = audio[name]; if (!a) return;
      try { a.pause(); a.currentTime = 0; } catch {}
    }
    function fadeOutSound(name, duration = 1200) {
      return new Promise((resolve) => {
        const a = audio[name];
        if (!a || a.paused) { resolve(); return; }
        const startVol = a.volume;
        const steps = 24;
        let i = 0;
        const tick = setInterval(() => {
          i++;
          a.volume = Math.max(0, startVol * (1 - i / steps));
          if (i >= steps) {
            clearInterval(tick);
            a.pause();
            a.currentTime = 0;
            a.volume = startVol;
            resolve();
          }
        }, duration / steps);
      });
    }
    function fadeInSound(name, duration = 800) {
      if (!audioEnabled) return;
      const a = audio[name];
      const cfg = SOUNDS[name];
      if (!a || !cfg) return;
      const target = cfg.volume;
      a.volume = 0;
      try { a.currentTime = 0; a.play().catch(() => {}); } catch {}
      const steps = 20;
      let i = 0;
      const tick = setInterval(() => {
        i++;
        a.volume = Math.min(target, target * (i / steps));
        if (i >= steps) clearInterval(tick);
      }, duration / steps);
    }

    const audioGate = document.getElementById('audioGate');
    function unlockAudio() {
      if (audioEnabled) return;
      // Prime each audio element so subsequent .play() works without user gesture
      const primes = Object.values(audio).map((a) => {
        const wasMuted = a.muted;
        a.muted = true;
        return a.play().then(() => { a.pause(); a.currentTime = 0; a.muted = wasMuted; }).catch(() => { a.muted = wasMuted; });
      });
      Promise.allSettled([...primes, bgPlaylist.prime()]).then(() => {
        audioEnabled = true;
        audioGate.classList.add('hidden');
        // If the game is already in lobby state, start the theme
        if (gameState.status === 'lobby') playSound('theme');
      });
    }
    audioGate.addEventListener('click', unlockAudio);
    // Also unlock on any keypress, in case the gate is hidden but audio isn't enabled yet
    document.addEventListener('keydown', () => { if (!audioEnabled) unlockAudio(); }, { once: false });

    const lobbyScreen    = document.getElementById('lobbyScreen');
    const gameScreen     = document.getElementById('gameScreen');
    const questionOverlay = document.getElementById('questionOverlay');
    const presenterBoard = document.getElementById('presenterBoard');
    const presenterScores = document.getElementById('presenterScores');
    const roundPill      = document.getElementById('roundPill');
    const cluesPill      = document.getElementById('cluesPill');
    const playerList     = document.getElementById('playerList');
    const buzzBanner     = document.getElementById('buzzBanner');
    const buzzName       = document.getElementById('buzzName');
    const roundNotif     = document.getElementById('roundNotif');
    const roundNotifTitle = document.getElementById('roundNotifTitle');

    /* ── WebSocket ─────────────────────────────────────────────────────────── */
    const wsUrl = `${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.host}/ws?gameId=${encodeURIComponent(gameId)}`;
    let ws;
    let lastStateTime = 0;

    function sendPing() {
      if (!ws || ws.readyState !== 1) return;
      const t = Date.now();
      ws.send(JSON.stringify({ type: 'PING', clientTime: t }));
    }

    function connect() {
      if (ws) { ws.onclose = null; ws.close(); }
      ws = new WebSocket(wsUrl);
      ws.addEventListener('open', () => {
        sendPing();
      });
      ws.addEventListener('close', () => setTimeout(connect, 2000));
      ws.addEventListener('message', onMessage);
    }
    connect();

    // Heartbeat
    setInterval(() => {
      if (ws && ws.readyState === 1) sendPing();
      else if (!ws || ws.readyState === 3) connect();
    }, 10000);

    function onMessage(event) {
      const status = document.getElementById('conn-status');
      const msg = JSON.parse(event.data);

      if (msg.type === 'PONG') {
        if (msg.clientTime != null && typeof msg.clientTime === 'number') {
          offset = msg.serverTime - (msg.clientTime + Date.now()) / 2;
        } else {
          offset = msg.serverTime - Date.now();
        }
        if (status) status.textContent = 'CONNECTED';
        return;
      }

      console.log('[Presenter] Message:', msg.type, msg);

      if (msg.type === 'SYNC_STATE' || msg.type === 'BOARD_STATE') {
        applySyncState(msg);
        return;
      }

      if (msg.type === 'PLAYER_JOINED') {
        // Player chip added via SYNC_STATE usually, but we can handle it for responsiveness
        const chip = document.createElement('div');
        chip.id = 'pl-' + msg.playerId;
        chip.style.cssText = 'background:rgba(74,48,160,0.5);border:1px solid var(--border);border-radius:12px;padding:.4rem 1rem;font-family:Fredoka,sans-serif;font-size:1.1rem;';
        chip.textContent = msg.displayName;
        playerList.appendChild(chip);
      }

      if (msg.type === 'PLAYER_KICKED') {
        document.getElementById('pl-' + msg.playerId)?.remove();
      }

      if (msg.type === 'GAME_START') {
        if (msg.soundEffects === false) soundEffectsEnabled = false;
        startIntroSequence();
      }

      if (msg.type === 'QUESTION_OPEN') {
        buzzBanner.classList.add('hidden');
        const valLabel = '$' + msg.value + (msg.isDailyDouble ? ' ★ DAILY DOUBLE' : '');
        document.getElementById('qCategory').textContent = msg.categoryTitle + ' · ' + valLabel;
        document.getElementById('qText').textContent = msg.questionText;
        questionOverlay.classList.remove('hidden');
        bgPlaylist.fadeOut(600);
        if (msg.isDailyDouble) playSound('dailyDouble');
      }

      if (msg.type === 'QUESTION_RESULT') {
        playSound(msg.correct ? 'correct' : 'incorrect');
      }

      if (msg.type === 'BUZZ_WINNER') {
        buzzName.textContent = msg.displayName + ' BUZZED IN';
        buzzBanner.classList.remove('hidden');
        highlightBuzzedPlayer(msg.displayName);
      }

      if (msg.type === 'QUESTION_CLOSED') {
        questionOverlay.classList.add('hidden');
        buzzBanner.classList.add('hidden');
        highlightBuzzedPlayer(null);
        bgPlaylist.fadeIn(1000);
      }

      if (msg.type === 'SCORE_UPDATE') {
        gameState.scores = msg.scores || gameState.scores;
        gameState.teams = msg.teams || gameState.teams;
        renderScores();
      }

      if (msg.type === 'ROUND_ADVANCE') {
        roundNotifTitle.textContent = msg.roundTitle;
        roundNotif.classList.remove('hidden');
        playSound('roundOver');
        setTimeout(() => roundNotif.classList.add('hidden'), 3500);
        // Re-fill the new round's board with animation
        pendingBoardReveal = true;
      }

      if (msg.type === 'START_FINAL_JEOPARDY') {
        bgPlaylist.stop();
        // Dramatic full-screen FJ announcement for a few seconds before showing the wager state
        let fjAnnounce = document.getElementById('fjAnnounce');
        if (!fjAnnounce) {
          fjAnnounce = document.createElement('div');
          fjAnnounce.id = 'fjAnnounce';
          fjAnnounce.style.cssText = 'position:absolute;inset:0;background:#0d0a1e;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:80;text-align:center;gap:1.5rem;';
          fjAnnounce.innerHTML = `
            <div style="font-family:'Anton',sans-serif;font-size:2.8rem;color:var(--muted);letter-spacing:0.38em;text-transform:uppercase;">Final</div>
            <div style="font-family:'Anton',sans-serif;font-size:9rem;color:var(--gold);letter-spacing:0.06em;line-height:1;text-shadow:0 0 60px rgba(255,200,61,0.5);">JEOPARTY</div>
            ${msg.category ? `<div style="font-family:'Anton',sans-serif;font-size:2.4rem;color:var(--ink);letter-spacing:0.14em;margin-top:0.5rem;">${String(msg.category).toUpperCase()}</div>` : ''}
            <div style="font-family:'Space Grotesk',sans-serif;font-size:1.1rem;color:var(--dim);letter-spacing:0.18em;margin-top:1rem;">Players are setting their wagers…</div>
          `;
          document.getElementById('scale-root')?.appendChild(fjAnnounce);
        } else {
          fjAnnounce.style.display = 'flex';
        }
        // After 10 seconds, replace with the board question overlay
        setTimeout(() => {
          if (fjAnnounce) fjAnnounce.style.display = 'none';
          questionOverlay.classList.add('hidden');
          document.getElementById('qCategory').textContent =
            msg.category ? `FINAL JEOPARTY · ${msg.category.toUpperCase()}` : 'FINAL JEOPARTY';
          document.getElementById('qText').textContent = 'Players are entering their wagers…';
          questionOverlay.classList.remove('hidden');
        }, 10000);
      }

      if (msg.type === 'FINAL_JEOPARDY_START') {
        document.getElementById('qCategory').textContent =
          msg.category ? `FINAL JEOPARDY · ${msg.category}` : 'FINAL JEOPARDY';
        document.getElementById('qText').textContent = msg.questionText;
        playSound('think');

        // Inject countdown styles once
        if (!document.getElementById('fj-countdown-style')) {
          const cs = document.createElement('style');
          cs.id = 'fj-countdown-style';
          cs.textContent = `
            @keyframes fjTickPulse { 0%{transform:scale(1)} 8%{transform:scale(1.12)} 16%{transform:scale(1)} }
            @keyframes fjCountIn   { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
            #fjCountdown { animation: fjCountIn .4s ease both; }
            #fjCountdown.urgent { color: #FF4D4D !important; text-shadow: 0 0 24px rgba(255,77,77,.7); }
            #fjCountdown .fj-tick { display:inline-block; animation: fjTickPulse .4s ease; }
          `;
          document.head.appendChild(cs);
        }

        // Remove any existing countdown
        document.getElementById('fjCountdown')?.remove();

        // Build countdown element
        const cdEl = document.createElement('div');
        cdEl.id = 'fjCountdown';
        cdEl.style.cssText = [
          'position:absolute',
          'bottom:48px',
          'right:60px',
          'font-family:"Anton",sans-serif',
          'font-size:7rem',
          'color:#F0C040',
          'text-shadow:0 4px 20px rgba(0,0,0,.6)',
          'line-height:1',
          'letter-spacing:.02em',
          'z-index:15',
          'pointer-events:none',
          'user-select:none',
        ].join(';');
        // Append to scale-root so position is relative to the full presenter canvas,
        // not the question overlay (whose position:absolute we must not override).
        document.getElementById('scale-root')?.appendChild(cdEl);

        let remaining = 30;
        function updateCd() {
          cdEl.innerHTML = `<span class="fj-tick">${remaining}</span>`;
          if (remaining <= 10) cdEl.classList.add('urgent');
          // Re-trigger pulse by replacing node
          const tick = cdEl.querySelector('.fj-tick');
          if (tick) {
            tick.style.animation = 'none';
            tick.getBoundingClientRect(); // force reflow
            tick.style.animation = '';
          }
        }
        updateCd();
        window._fjCountdownTimer = setInterval(() => {
          remaining--;
          if (remaining < 0) {
            clearInterval(window._fjCountdownTimer);
            cdEl.remove();
            return;
          }
          updateCd();
        }, 1000);
      }

      if (msg.type === 'FINAL_RESPONSE_REVEAL') {
        stopSound('think');
        // Kill countdown if still running
        if (window._fjCountdownTimer) { clearInterval(window._fjCountdownTimer); window._fjCountdownTimer = null; }
        document.getElementById('fjCountdown')?.remove();

        // Inject animation styles once
        if (!document.getElementById('fj-reveal-style')) {
          const st = document.createElement('style');
          st.id = 'fj-reveal-style';
          st.textContent = `
            @keyframes fjCardIn  { from{transform:translateY(110%) scale(.92);opacity:0} to{transform:translateY(0) scale(1);opacity:1} }
            @keyframes fjCardOut { from{transform:scale(1);opacity:1} to{transform:scale(.95);opacity:0} }
            @keyframes fjFadeIn  { from{opacity:0;filter:blur(10px)} to{opacity:1;filter:blur(0)} }
            @keyframes fjBadge   { 0%{transform:scaleY(0);opacity:0} 70%{transform:scaleY(1.1)} 100%{transform:scaleY(1);opacity:1} }
            @keyframes fjScore   { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
            .fj-card-enter  { animation: fjCardIn  .65s cubic-bezier(.22,1,.36,1) forwards; }
            .fj-card-leave  { animation: fjCardOut .7s ease-in forwards; }
            .fj-answer-show { animation: fjFadeIn  .9s ease .7s both; }
            .fj-badge-show  { animation: fjBadge   .5s cubic-bezier(.34,1.56,.64,1) both; }
            .fj-score-show  { animation: fjScore   .6s ease both; }
          `;
          document.head.appendChild(st);
        }

        // Resolve avatar appearance
        const av = avFromDb(msg.avatarColor ?? 0, msg.avatarShape ?? 0);
        const shapeCSS = av.clipPath ? `clip-path:${av.clipPath}` : `border-radius:${av.radius || '50%'}`;
        const resultColor = msg.correct ? '#5EEBC1' : '#FF4D4D';
        const resultLabel = msg.correct ? '✓  CORRECT' : '✗  WRONG';
        const scoreDir   = msg.correct ? `+$${msg.wager.toLocaleString()}` : `-$${msg.wager.toLocaleString()}`;

        // Update scoreboard data
        const scoreLine = gameState.scores.find((x) => x.playerId === msg.playerId);
        if (scoreLine) scoreLine.score = msg.newScore;

        // Build or reuse the reveal overlay
        let overlay = document.getElementById('fjRevealOverlay');
        if (!overlay) {
          overlay = document.createElement('div');
          overlay.id = 'fjRevealOverlay';
          overlay.style.cssText = 'position:absolute;inset:0;z-index:85;display:flex;align-items:center;justify-content:center;background:rgba(14,11,34,.82);';
          document.getElementById('scale-root')?.appendChild(overlay);
        }
        overlay.style.display = 'flex';
        overlay.style.opacity = '1';
        overlay.style.transition = '';
        overlay.innerHTML = `
          <div class="fj-card-enter" style="background:linear-gradient(150deg,#1c1847,#110e2e);border:2px solid rgba(255,255,255,.1);border-radius:28px;padding:48px 72px;display:flex;flex-direction:column;align-items:center;gap:28px;min-width:640px;max-width:860px;box-shadow:0 48px 96px rgba(0,0,0,.7);">
            <div style="display:flex;align-items:center;gap:22px;">
              <div style="width:90px;height:90px;background:${av.bg};${shapeCSS};display:flex;align-items:center;justify-content:center;font-size:48px;line-height:1;color:#0E0B22;font-family:'Anton',sans-serif;box-shadow:0 10px 30px rgba(0,0,0,.5);flex-shrink:0;">${av.glyph}</div>
              <div style="font-family:'Anton',sans-serif;font-size:3.8rem;color:#fff;letter-spacing:.04em;">${msg.displayName.toUpperCase()}</div>
            </div>
            <div style="font-family:'Space Grotesk',sans-serif;font-size:1rem;color:rgba(255,255,255,.38);letter-spacing:.2em;text-transform:uppercase;">Wagered $${msg.wager.toLocaleString()}</div>
            <div class="fj-answer-show" style="background:rgba(255,255,255,.07);border-radius:18px;padding:26px 40px;width:100%;text-align:center;font-family:'Space Grotesk',sans-serif;font-size:2.1rem;color:#fff;min-height:80px;display:flex;align-items:center;justify-content:center;font-style:italic;">
              "${(msg.answer || '— no response —').replace(/</g,'&lt;')}"
            </div>
            <div id="fjResultBadge" style="opacity:0;">
              <div style="background:${resultColor};border-radius:14px;padding:18px 56px;font-family:'Anton',sans-serif;font-size:3rem;color:#0E0B22;letter-spacing:.1em;">${resultLabel}</div>
            </div>
            <div id="fjScoreChange" style="opacity:0;font-family:'Anton',sans-serif;font-size:2rem;color:${resultColor};letter-spacing:.08em;">${scoreDir} → $${msg.newScore.toLocaleString()}</div>
          </div>
        `;

        // Reveal result badge + score after 2.5 s
        setTimeout(() => {
          const badge = document.getElementById('fjResultBadge');
          if (badge) { badge.style.opacity = '1'; badge.firstElementChild?.classList.add('fj-badge-show'); }
          const scoreEl = document.getElementById('fjScoreChange');
          if (scoreEl) scoreEl.classList.add('fj-score-show');
          renderScores();
        }, 2500);

        // Fade the card out after 8.5 s so the next reveal can slide in cleanly
        setTimeout(() => {
          if (!overlay) return;
          overlay.style.transition = 'opacity .9s ease';
          overlay.style.opacity = '0';
          setTimeout(() => { if (overlay) { overlay.style.display = 'none'; overlay.style.transition = ''; overlay.style.opacity = '1'; } }, 900);
        }, 8500);
      }

      if (msg.type === 'GAME_OVER') {
        gameState.scores = msg.scores || gameState.scores;
        gameState.teams = msg.teams || gameState.teams;
        renderScores();
        questionOverlay.classList.add('hidden');
        bgPlaylist.stop();
        stopSound('think');
        if (window._fjCountdownTimer) { clearInterval(window._fjCountdownTimer); window._fjCountdownTimer = null; }
        document.getElementById('fjCountdown')?.remove();
        playSound('timesUp');
        showPresenterGameOver(msg);
      }
    }

    function showPresenterGameOver(payload = null) {
      let over = document.getElementById('presenterGameOver');
      if (!over) {
        over = document.createElement('div');
        over.id = 'presenterGameOver';
        over.style.cssText = 'position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,#1F1947 0%,#0E0B22 70%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem;z-index:60;text-align:center;';
        document.getElementById('scale-root')?.appendChild(over);
      }

      const sourceScores = payload?.scores || gameState.scores || [];
      const sourceTeams = payload?.teams || gameState.teams || [];
      const useTeams = !!(gameState.teamMode && sourceTeams.length);

      // Sort lowest → highest so winner is revealed last
      const standings = (useTeams
        ? sourceTeams.map((t, i) => ({ name: t.name || `Team ${i + 1}`, score: Number(t.score) || 0 }))
        : sourceScores.map((s) => ({ name: s.displayName || 'Player', score: Number(s.score) || 0 }))
      ).sort((a, b) => a.score - b.score);
      const total = standings.length;

      over.innerHTML = `
        <div style="width:min(92vw,1260px);max-height:94vh;display:flex;flex-direction:column;align-items:center;gap:1.2rem;padding:1rem 0.5rem;overflow:hidden;">
          <div id="goTitle" style="font-family:'Anton',sans-serif;font-size:2.2rem;color:var(--dim);letter-spacing:0.26em;opacity:0;transition:opacity 0.6s ease;">GAME OVER</div>
          <div id="goList" style="width:min(980px,100%);display:flex;flex-direction:column;gap:0.5rem;overflow:visible;"></div>
          <button id="presenterHomeBtn" style="opacity:0;transition:opacity 0.5s ease 0.3s;font-family:'Anton',sans-serif;font-size:1.35rem;background:var(--gold);color:#0E0B22;border:none;padding:0.95rem 2.2rem;border-radius:999px;cursor:pointer;letter-spacing:0.08em;box-shadow:0 12px 0 #B88A1F,0 22px 40px rgba(255,200,61,0.25);">← BACK TO HOME</button>
        </div>
      `;

      // Title fades in immediately
      requestAnimationFrame(() => {
        const title = document.getElementById('goTitle');
        if (title) title.style.opacity = '1';
      });

      const list = document.getElementById('goList');
      const initDelay = 400;
      const step = total <= 6 ? 750 : total <= 12 ? 550 : 380;

      standings.forEach((entry, i) => {
        const isWinner = i === total - 1;
        const rank = total - i; // rank 1 = winner (last shown)
        const dollars = (n) => `${n < 0 ? '-$' : '$'}${Math.abs(n).toLocaleString()}`;

        setTimeout(() => {
          const row = document.createElement('div');

          if (isWinner) {
            row.style.cssText = [
              'display:grid;grid-template-columns:56px 1fr auto;align-items:center;gap:1rem;',
              'padding:1.1rem 1.4rem;border-radius:16px;',
              'border:2px solid var(--gold);',
              'background:linear-gradient(135deg,rgba(255,200,61,0.2) 0%,rgba(124,92,255,0.18) 100%);',
              'font-family:\'Anton\',sans-serif;letter-spacing:0.03em;',
              'animation:go-slide-in 0.5s cubic-bezier(0.2,0.8,0.3,1.1) forwards;',
            ].join('');
            row.innerHTML = `
              <span id="goTrophy" style="font-size:2rem;text-align:center;display:block;">🏆</span>
              <span style="font-size:clamp(1.4rem,3vw,2rem);color:var(--gold);text-align:left;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${entry.name.toUpperCase()}</span>
              <span style="font-size:clamp(1.2rem,2.6vw,1.7rem);color:var(--gold);">${dollars(entry.score)}</span>
            `;
            list?.prepend(row);

            // After slide-in lands, start dance + glow
            setTimeout(() => {
              row.style.animation = 'go-winner-dance 1s ease-in-out 3, go-winner-glow 2.2s ease-in-out 0.5s infinite';
            }, 600);

            // Show back button after winner settles
            setTimeout(() => {
              const btn = document.getElementById('presenterHomeBtn');
              if (btn) btn.style.opacity = '1';
            }, 1400);
          } else {
            row.style.cssText = [
              'display:grid;grid-template-columns:48px 1fr auto;align-items:center;gap:0.9rem;',
              'padding:0.7rem 1.1rem;border-radius:12px;',
              'border:1px solid var(--line);background:var(--bg2);',
              'font-family:\'Anton\',sans-serif;letter-spacing:0.03em;',
              'animation:go-slide-in 0.45s cubic-bezier(0.2,0.8,0.3,1.1) forwards;',
            ].join('');
            row.innerHTML = `
              <span style="font-size:1rem;color:var(--dim);text-align:center;">${rank}</span>
              <span style="font-size:clamp(0.95rem,2.1vw,1.25rem);color:var(--ink);text-align:left;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${entry.name.toUpperCase()}</span>
              <span style="font-size:clamp(0.9rem,1.9vw,1.15rem);color:${entry.score < 0 ? 'var(--red)' : 'var(--gold)'};">${entry.score < 0 ? '-$' : '$'}${Math.abs(entry.score).toLocaleString()}</span>
            `;
            list?.prepend(row);
          }
        }, initDelay + i * step);
      });

      document.getElementById('presenterHomeBtn').addEventListener('click', () => { location.href = '/'; });
      over.style.display = 'flex';
    }

    function hidePresenterGameOver() {
      const over = document.getElementById('presenterGameOver');
      if (over) over.style.display = 'none';
    }

    /* ── Intro sequence ─────────────────────────────────────────────────────── */
    // Timeline (aligned to ~23s intro audio):
    //   0s    GAME_START — audio crossfade + lobby fades out
    //   0s    3D fly-in begins (10s)
    //   10s   Logo settles up to top of frame (0.7s)
    //   10.7s Player intros begin (one at a time, ~2s each)
    //   ~20s  Logo runs fly-out (2.5s) while last card slides off
    //   23s   Board fills in
    async function startIntroSequence() {
      awaitingIntro = true;
      crossfading = true;

      const flash = document.getElementById('jpFlash');
      flash.innerHTML = '';
      flash.appendChild(Object.assign(document.createElement('div'), { className: 'jp-stars' }));
      flash.style.opacity = '';
      flash.classList.remove('hidden');

      lobbyScreen.classList.add('crossfade-out');
      schedule(() => {
        lobbyScreen.classList.add('hidden');
        lobbyScreen.classList.remove('crossfade-out');
        if (window.__disposeLobbyLogo) window.__disposeLobbyLogo();
      }, 1200);

      gameScreen.classList.add('hidden');
      gameScreen.classList.remove('crossfade-out');

      const intro = audio.intro;
      const introDurMs = (audioEnabled && isFinite(intro.duration) && intro.duration > 0)
        ? intro.duration * 1000
        : 23000;

      const FLY_IN_MS = 10000;
      const SETTLE_MS = 700;
      const FLY_OUT_MS = 2500;
      const players = (gameState.scores || []).slice();

      // Window available for player intros = total − fly-in − settle − fly-out − safety
      const playerWindow = Math.max(0, introDurMs - FLY_IN_MS - SETTLE_MS - FLY_OUT_MS - 300);

      // Compute simultaneous columns so each slot is visible for ≥1500ms
      const MIN_SLOT_MS = 1500;
      const MAX_COLS = 5;
      const maxSlotsInWindow = Math.max(1, Math.floor(playerWindow / MIN_SLOT_MS));
      const columns = players.length > 0
        ? Math.min(MAX_COLS, Math.max(1, Math.ceil(players.length / maxSlotsInWindow)))
        : 1;
      const numSlots = players.length > 0 ? Math.ceil(players.length / columns) : 0;
      const perSlot = numSlots > 0 ? Math.min(2500, Math.floor(playerWindow / numSlots)) : 0;

      const playerStart = FLY_IN_MS + SETTLE_MS + 200;
      const playerEnd = playerStart + numSlots * perSlot;
      const flyOutStart = Math.max(playerEnd + 100, introDurMs - FLY_OUT_MS);

      // Mount Three.js intro
      if (!introController && window.__createJeopartyIntro) {
        try {
          introController = await window.__createJeopartyIntro(flash);
        } catch (e) {
          console.warn('[Intro] Failed to load 3D intro module:', e);
        }
      }

      // Schedule player intro slots — each slot shows `columns` cards simultaneously
      for (let slot = 0; slot < numSlots; slot++) {
        const slotStart = slot * columns;
        const slotPlayers = players.slice(slotStart, slotStart + columns);
        schedule(
          () => showPlayerSlot(slotPlayers, slotStart, players.length, perSlot, columns),
          playerStart + slot * perSlot
        );
      }

      if (audioEnabled) {
        fadeOutSound('theme', 1500);
        fadeInSound('intro', 1000);
        const onEnd = () => {
          intro.removeEventListener('ended', onEnd);
          finishIntroAndRevealBoard();
        };
        intro.addEventListener('ended', onEnd);
      }
      schedule(finishIntroAndRevealBoard, introDurMs + 200);

      if (introController) {
        try {
          await introController.runFlyIn();
          await introController.settleToTop();
          // Idle continues automatically in the render loop until runFlyOut.
          // Wait until it's time for the exit:
          const now = performance.now();
          const introStartTime = now - (FLY_IN_MS + SETTLE_MS);
          const waitMs = Math.max(0, flyOutStart - (now - introStartTime));
          await new Promise((resolve) => schedule(resolve, waitMs));
          if (!awaitingIntro) return;
          await introController.runFlyOut();
        } catch (e) {
          console.warn('[Intro] animation error:', e);
        }
      }
    }

    function schedule(fn, delay) {
      const id = setTimeout(fn, delay);
      introTimeouts.push(id);
      return id;
    }

    // Column positions and entry animations per column count
    const SLOT_X = {
      1: ['50%'],
      2: ['25%', '75%'],
      3: ['17%', '50%', '83%'],
      4: ['13%', '37%', '63%', '87%'],
      5: ['10%', '28%', '50%', '72%', '90%'],
    };
    // Each column flies in from a distinct direction; outer cols from sides, inner from top/bottom
    const SLOT_ANIM = {
      1: ['player-intro-slide'],
      2: ['player-intro-from-left', 'player-intro-slide'],
      3: ['player-intro-from-left', 'player-intro-from-bottom', 'player-intro-slide'],
      4: ['player-intro-from-left', 'player-intro-from-bottom', 'player-intro-from-top', 'player-intro-slide'],
      5: ['player-intro-from-left', 'player-intro-from-bottom', 'player-intro-from-top', 'player-intro-from-bottom', 'player-intro-slide'],
    };

    function showPlayerSlot(slotPlayers, startIdx, total, durationMs, numCols) {
      const flash = document.getElementById('jpFlash');
      if (!flash || flash.classList.contains('hidden')) return;
      // Clear any leftover cards from the previous slot
      flash.querySelectorAll('.player-intro-card').forEach(c => c.remove());

      const actualCols = slotPlayers.length;
      const xPos  = SLOT_X[actualCols]  || SLOT_X[1];
      const anims = SLOT_ANIM[actualCols] || SLOT_ANIM[1];
      const sizeClass = numCols >= 5 ? 'pi-xs' : numCols >= 3 ? 'pi-sm' : '';

      slotPlayers.forEach((player, col) => {
        const idx = startIdx + col + 1;
        const av = avFromDb(player.avatarColor, player.avatarShape);
        const score = player.score || 0;
        const scoreStr = score < 0 ? `-$${Math.abs(score).toLocaleString()}` : `$${score.toLocaleString()}`;
        const shapeStyle = av.clipPath ? `clip-path:${av.clipPath}` : `border-radius:${av.radius}`;
        const card = document.createElement('div');
        card.className = 'player-intro-card' + (sizeClass ? ' ' + sizeClass : '');
        card.style.left = xPos[col] || '50%';
        card.style.animation = `${anims[col] || 'player-intro-slide'} ${durationMs}ms ease-out forwards`;
        card.innerHTML = `
          <div class="pi-eyebrow">Player ${idx} of ${total}</div>
          <div class="pi-avatar" style="background:${av.bg};${shapeStyle}">${av.glyph}</div>
          <div class="pi-name">${player.displayName || '—'}</div>
          <div class="pi-score" style="color:${av.bg}">${scoreStr}</div>
        `;
        flash.appendChild(card);
      });
    }

    function finishIntroAndRevealBoard() {
      if (!awaitingIntro) return;
      awaitingIntro = false;
      // Cancel any pending intro timeouts (so a stray player card doesn't pop in over the board)
      introTimeouts.forEach(clearTimeout);
      introTimeouts = [];

      const flash = document.getElementById('jpFlash');

      // Reveal the game screen behind the flash, faded out, then fade it in.
      gameScreen.classList.remove('hidden');
      gameScreen.classList.add('crossfade-out');
      void gameScreen.offsetWidth;

      // Render the board with its fill animation as the flash dissolves
      playSound('boardFill');
      // Wait for boardFill to finish before starting bg music; fall back after 4s
      const _bfEl = audio.boardFill;
      const _startBg = () => bgPlaylist.fadeIn(1500);
      if (_bfEl) {
        _bfEl.addEventListener('ended', _startBg, { once: true });
        setTimeout(() => { _bfEl.removeEventListener('ended', _startBg); bgPlaylist.isPlaying() || _startBg(); }, 4000);
      } else {
        setTimeout(_startBg, 2500);
      }
      renderBoard(true);

      requestAnimationFrame(() => {
        gameScreen.classList.remove('crossfade-out');
        flash.style.opacity = '0';
      });

      // Drop the flash + clear the crossfade lock once it's faded out
      setTimeout(() => {
        flash.classList.add('hidden');
        flash.innerHTML = '';
        flash.style.opacity = '';
        if (introController) { try { introController.dispose(); } catch {} introController = null; }
        crossfading = false;
      }, 700);
    }

    function applySyncState(state) {
      if (state.serverTime && state.serverTime < lastStateTime) {
        console.warn('[Presenter] Ignoring stale state sync');
        return;
      }
      lastStateTime = state.serverTime || Date.now();
      if (state.serverTime) offset = state.serverTime - Date.now();

      const prevStatus = gameState.status;
      const prevRound = gameState.currentRound;

      gameState.board = state.board;
      gameState.usedQuestions = new Set(state.usedQuestions || []);
      gameState.scores = state.scores || [];
      gameState.teams = state.teams || [];
      gameState.currentPicker = state.currentPicker;
      gameState.currentRound = state.currentRound ?? 0;
      gameState.totalRounds = state.totalRounds ?? 1;
      gameState.teamMode = state.teamMode ?? false;
      gameState.status = state.status || 'lobby';

      // Show the audio gate the first time we land on the lobby (audio still locked)
      if (gameState.status === 'lobby' && !audioEnabled) {
        audioGate.classList.remove('hidden');
      }
      // Start theme on lobby if not already playing
      if (gameState.status === 'lobby' && audioEnabled && audio.theme.paused && !awaitingIntro) {
        playSound('theme');
      }
      // If we land mid-game (page reload during active state), stop theme and resume bg music
      if (gameState.status !== 'lobby' && audioEnabled && !audio.theme.paused && !awaitingIntro) {
        fadeOutSound('theme', 600);
      }
      if (gameState.status === 'active' && audioEnabled && !bgPlaylist.isPlaying() && !awaitingIntro) {
        bgPlaylist.fadeIn(1500);
      }

      // Detect a round change mid-active (e.g. round 0 → 1) to trigger board re-fill
      if (gameState.status === 'active' && prevStatus === 'active' && gameState.currentRound !== prevRound) {
        pendingBoardReveal = true;
      }

      const inActive = gameState.status === 'active' || gameState.status === 'final_jeopardy' || gameState.status === 'finished';

      if (awaitingIntro || crossfading) {
        // Intro or crossfade is in flight — leave screens to that controller
      } else if (inActive) {
        lobbyScreen.classList.add('hidden');
        gameScreen.classList.remove('hidden');
      } else {
        lobbyScreen.classList.remove('hidden');
        gameScreen.classList.add('hidden');
      }

      if (gameState.status === 'finished') {
        showPresenterGameOver({
          scores: gameState.scores,
          teams: gameState.teams,
        });
      } else {
        hidePresenterGameOver();
      }

      // Render players in lobby
      playerList.innerHTML = '';
      gameState.scores.forEach(p => {
        const chip = document.createElement('div');
        chip.id = 'pl-' + p.playerId;
        chip.style.cssText = 'background:rgba(74,48,160,0.5);border:1px solid var(--border);border-radius:12px;padding:.4rem 1rem;font-family:Fredoka,sans-serif;font-size:1.1rem;text-transform:uppercase;';
        chip.textContent = p.displayName;
        playerList.appendChild(chip);
      });

      if (!awaitingIntro && !crossfading) {
        const animate = pendingBoardReveal && inActive;
        pendingBoardReveal = false;
        if (animate) playSound('boardFill');
        renderBoard(animate);
      }
      renderScores();
      updateRoundBadge();

      // Restore active question overlay
      if (state.activeQuestion) {
        const aq = state.activeQuestion;
        const valLabel = '$' + aq.value + (aq.isDailyDouble ? ' ★ DAILY DOUBLE' : '');
        document.getElementById('qCategory').textContent = aq.categoryTitle + ' · ' + valLabel;
        document.getElementById('qText').textContent = aq.questionText;
        questionOverlay.classList.remove('hidden');
        // Restore buzz winner if present
        if (state.buzzWinner) {
          buzzName.textContent = state.buzzWinner.displayName + ' BUZZED IN';
          buzzBanner.classList.remove('hidden');
          highlightBuzzedPlayer(state.buzzWinner.displayName);
        } else {
          buzzBanner.classList.add('hidden');
          highlightBuzzedPlayer(null);
        }
      } else {
        questionOverlay.classList.add('hidden');
        buzzBanner.classList.add('hidden');
        highlightBuzzedPlayer(null);
      }
    }

    /* ── Render board ──────────────────────────────────────────────────────── */
    function renderBoard(animate = false) {
      if (!gameState.board) return;
      const cats = gameState.board.categories || [];
      const numCats = cats.length;
      if (!numCats) return;
      const maxQ = Math.max(...cats.map((c) => c.questions.length));
      presenterBoard.style.gridTemplateColumns = `repeat(${numCats}, 1fr)`;
      presenterBoard.style.gridTemplateRows = `120px repeat(${maxQ}, 1fr)`;
      presenterBoard.innerHTML = '';
      presenterBoard.classList.toggle('filling', animate);

      // Category headers (row 0)
      cats.forEach((cat, col) => {
        const h = document.createElement('div');
        h.className = 'presenter-cat-header';
        h.textContent = cat.title;
        if (animate) h.style.animationDelay = `${col * 0.08}s`;
        presenterBoard.appendChild(h);
      });

      // Question rows
      let totalQ = 0, usedQ = 0;
      for (let qi = 0; qi < maxQ; qi++) {
        cats.forEach((cat, col) => {
          const q = cat.questions.sort((a, b) => a.value - b.value)[qi];
          if (!q) { presenterBoard.appendChild(document.createElement('div')); return; }
          totalQ++;
          const used = gameState.usedQuestions.has(q.id);
          if (used) usedQ++;
          const cell = document.createElement('div');
          cell.className = 'presenter-q-cell' + (used ? ' used' : '');
          if (!used) cell.textContent = '$' + q.value;
          if (animate) cell.style.animationDelay = `${0.25 + col * 0.08 + qi * 0.06}s`;
          presenterBoard.appendChild(cell);
        });
      }
      updateCluesPill(usedQ, totalQ);

      if (animate) {
        // Total stagger ≈ headers + (maxQ rows). Remove .filling once done so future
        // re-renders (cells flipping to used, etc.) don't replay the animation.
        const totalDuration = (0.25 + (numCats - 1) * 0.08 + (maxQ - 1) * 0.06 + 0.5) * 1000;
        setTimeout(() => presenterBoard.classList.remove('filling'), totalDuration);
      }
    }

    /* ── Render scores ─────────────────────────────────────────────────────── */
    function renderScores() {
      presenterScores.innerHTML = '';
      playerColorMap = {};
      const players = [...gameState.scores].sort((a, b) => b.score - a.score);
      const count = players.length;
      // Always fit in ≤2 rows: >6 players → 2 rows, else 1 row
      const rows = count > 6 ? 2 : 1;
      const cols = Math.ceil(count / rows);
      presenterScores.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
      // Scale down cards as columns increase to stay within the scores strip height
      const sizeCls = cols <= 6 ? '' : cols <= 9 ? 'pp-md' : 'pp-sm';
      presenterScores.style.gap = sizeCls === 'pp-sm' ? '6px' : sizeCls === 'pp-md' ? '9px' : '14px';
      presenterScores.style.padding = sizeCls === 'pp-sm' ? '12px 40px 20px' : sizeCls === 'pp-md' ? '14px 48px 24px' : '20px 56px 32px';
      players.forEach((p, i) => {
        const av = avFromDb(p.avatarColor, p.avatarShape);
        const color = av.bg;
        const glyph = av.glyph;
        playerColorMap[p.displayName] = color;
        const scoreColor = p.score < 0 ? 'var(--red)' : 'var(--gold)';
        const scoreStr = p.score < 0 ? `-$${Math.abs(p.score).toLocaleString()}` : `$${p.score.toLocaleString()}`;
        const card = document.createElement('div');
        card.className = `presenter-player-card${sizeCls ? ' ' + sizeCls : ''}`;
        card.style.borderColor = 'transparent';
        card.dataset.player = p.displayName;
        card.innerHTML = `
          <div class="presenter-player-avatar" style="background:${color};${av.clipPath ? `clip-path:${av.clipPath}` : `border-radius:${av.radius}`}">${glyph}</div>
          <div style="flex:1;min-width:0;">
            <div class="presenter-player-name">${p.displayName}</div>
            <div class="presenter-player-score" style="color:${scoreColor}">${scoreStr}</div>
          </div>`;
        presenterScores.appendChild(card);
      });
    }

    function highlightBuzzedPlayer(displayName) {
      document.querySelectorAll('.presenter-player-card').forEach(card => {
        const isBuzzed = card.dataset.player === displayName;
        card.classList.toggle('buzzed', isBuzzed);
        card.style.borderColor = isBuzzed ? '#FF3D8E' : 'transparent';
        card.style.boxShadow = isBuzzed ? '0 0 32px rgba(255, 61, 142, 0.4)' : 'none';
      });
    }

    function updateCluesPill(used, total) {
      if (cluesPill) cluesPill.textContent = `${used} OF ${total} CLUES`;
    }

    function updateRoundBadge() {
      if (roundPill) roundPill.textContent = `ROUND ${gameState.currentRound + 1} OF ${gameState.totalRounds}`;
      if (cluesPill && !cluesPill.textContent) cluesPill.textContent = '— CLUES';
    }
  </script>
</body>
</html>
