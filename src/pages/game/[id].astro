---
import '@/styles/global.css';
import QRCode from 'qrcode';
import { db, schema } from '@/lib/db';
import { eq } from 'drizzle-orm';

const gameId = String(Astro.params.id).toUpperCase();
const gameRows = await db.select({ id: schema.games.id, status: schema.games.status })
  .from(schema.games).where(eq(schema.games.id, gameId));
if (!gameRows.length) return Astro.redirect('/');

const joinUrl = `${Astro.url.origin}/join?code=${gameId}`;
const qrSvg = await QRCode.toString(joinUrl, { type: 'svg', color: { dark: '#FFC83D', light: '#0E0B22' }, margin: 1 });
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Jeoparty — {gameId}</title>
  <style>
    html, body { height: 100%; overflow: hidden; background: #0E0B22; margin: 0; }
    #scale-root { transform-origin: top left; }
    #conn-status { position: absolute; bottom: 10px; right: 10px; font-size: 0.7rem; color: #333; z-index: 100; opacity: 0.3; }
  </style>
</head>
<body>
  <div id="scale-root" class="presenter-root">

    <!-- Lobby screen (before game starts) -->
    <div id="lobbyScreen" style="height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2rem;">
      <div style="font-family:'Anton',sans-serif; font-size:7rem; font-weight:700; background:linear-gradient(135deg,#FFC83D,#FF3D8E); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; line-height:1;">JEOPARTY</div>
      <div class="join-code">{gameId}</div>
      <p style="font-family:'Anton',sans-serif; font-size:1.6rem; color:var(--muted);">Go to <strong style="color:var(--text);">{Astro.url.host}/join</strong> and enter the code above</p>
      <div set:html={qrSvg} style="width:220px; height:220px;" />
      <div id="playerList" style="display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; max-width:1200px; margin-top:0.5rem;"></div>
    </div>

    <!-- Active game screen -->
    <div id="gameScreen" class="hidden" style="height:100%; display:flex; flex-direction:column;">
      <!-- Top bar -->
      <div style="display:flex; align-items:center; justify-content:space-between; padding:32px 56px 24px; flex-shrink:0;">
        <div style="display:flex; align-items:baseline; gap:18px;">
          <span style="font-family:'Anton',sans-serif; font-size:56px; letter-spacing:0.02em; color:var(--gold); line-height:1;">JEOPARTY</span>
          <span style="font-size:18px; color:var(--dim); letter-spacing:0.18em;">ROOM · {gameId}</span>
        </div>
        <div style="display:flex; align-items:center; gap:28px;">
          <div id="roundPill" style="padding:10px 18px; border-radius:999px; border:1.5px solid var(--gold); color:var(--gold); font-family:'Anton',sans-serif; letter-spacing:0.12em; font-size:16px;"></div>
          <div id="cluesPill" style="padding:10px 18px; border-radius:999px; border:1.5px solid var(--line); color:var(--dim); font-family:'Anton',sans-serif; letter-spacing:0.12em; font-size:16px;"></div>
        </div>
      </div>
      <!-- Board -->
      <div style="flex:1; padding:0 56px 24px; display:flex; flex-direction:column; min-height:0;">
        <div id="presenterBoard" class="presenter-board-grid" style="flex:1; min-height:0;"></div>
      </div>
      <!-- Scoreboard -->
      <div id="presenterScores" style="padding:20px 56px 32px; display:grid; gap:14px; flex-shrink:0;"></div>
    </div>

    <!-- Question overlay -->
    <div id="questionOverlay" class="question-overlay hidden">
      <div class="q-category" id="qCategory"></div>
      <div class="q-text" id="qText"></div>
      <div id="buzzBanner" class="buzz-banner hidden">
        <span class="buzz-dot"></span>
        <span id="buzzName"></span>
      </div>
    </div>

    <!-- Round advance notification -->
    <div id="roundNotif" class="hidden" style="position:absolute;inset:0;background:rgba(10,5,30,0.92);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:50;animation:slide-up .3s ease;">
      <div style="font-family:'Anton',sans-serif;font-size:3rem;color:var(--muted);">Next Up</div>
      <div id="roundNotifTitle" style="font-family:'Anton',sans-serif;font-size:6rem;font-weight:700;color:var(--accent);"></div>
    </div>

    <!-- Host controls link (corner) -->
    <a href={`/game/${gameId}/host`} style="position:absolute;top:16px;right:16px;font-size:0.8rem;color:var(--muted);opacity:0.4;" title="Host Controls">⚙ Host</a>
    <div id="conn-status">CONNECTING...</div>
  </div>

  <script is:inline define:vars={{ gameId }}>
    // @ts-nocheck
    /* ── Scaling ───────────────────────────────────────────────────────────── */
    function scale() {
      const root = document.getElementById('scale-root');
      if (!root) return;
      const tw = 1920; const th = 1080;
      const s = Math.min(window.innerWidth / tw, window.innerHeight / th) || 1;
      root.style.width = tw + 'px';
      root.style.height = th + 'px';
      root.style.transform = `scale(${s})`;
      root.style.position = 'absolute';
      root.style.left = '50%';
      root.style.top = '50%';
      root.style.marginLeft = `-${(tw * s) / 2}px`;
      root.style.marginTop = `-${(th * s) / 2}px`;
      root.style.transformOrigin = 'top left';
    }
    scale();
    window.addEventListener('resize', scale);

    /* ── State ─────────────────────────────────────────────────────────────── */
    let gameState = { board: null, usedQuestions: new Set(), scores: [], teams: [], currentPicker: null, currentRound: 0, totalRounds: 1, teamMode: false };
    let offset = 0;
    const PLAYER_COLORS = ['#FFC83D', '#FF3D8E', '#5EEBC1', '#7C5CFF', '#FF8A3D', '#5BA9FF'];
    let playerColorMap = {};

    const lobbyScreen    = document.getElementById('lobbyScreen');
    const gameScreen     = document.getElementById('gameScreen');
    const questionOverlay = document.getElementById('questionOverlay');
    const presenterBoard = document.getElementById('presenterBoard');
    const presenterScores = document.getElementById('presenterScores');
    const roundPill      = document.getElementById('roundPill');
    const cluesPill      = document.getElementById('cluesPill');
    const playerList     = document.getElementById('playerList');
    const buzzBanner     = document.getElementById('buzzBanner');
    const buzzName       = document.getElementById('buzzName');
    const roundNotif     = document.getElementById('roundNotif');
    const roundNotifTitle = document.getElementById('roundNotifTitle');

    /* ── WebSocket ─────────────────────────────────────────────────────────── */
    const wsUrl = `${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.host}/ws?gameId=${encodeURIComponent(gameId)}`;
    let ws;
    let lastStateTime = 0;

    function sendPing() {
      if (!ws || ws.readyState !== 1) return;
      const t = Date.now();
      ws.send(JSON.stringify({ type: 'PING', clientTime: t }));
    }

    function connect() {
      if (ws) { ws.onclose = null; ws.close(); }
      ws = new WebSocket(wsUrl);
      ws.addEventListener('open', () => {
        sendPing();
      });
      ws.addEventListener('close', () => setTimeout(connect, 2000));
      ws.addEventListener('message', onMessage);
    }
    connect();

    // Heartbeat
    setInterval(() => {
      if (ws && ws.readyState === 1) sendPing();
      else if (!ws || ws.readyState === 3) connect();
    }, 10000);

    function onMessage(event) {
      const status = document.getElementById('conn-status');
      const msg = JSON.parse(event.data);

      if (msg.type === 'PONG') {
        if (msg.clientTime != null && typeof msg.clientTime === 'number') {
          offset = msg.serverTime - (msg.clientTime + Date.now()) / 2;
        } else {
          offset = msg.serverTime - Date.now();
        }
        if (status) status.textContent = 'CONNECTED';
        return;
      }

      console.log('[Presenter] Message:', msg.type, msg);

      if (msg.type === 'SYNC_STATE' || msg.type === 'BOARD_STATE') {
        applySyncState(msg);
        return;
      }

      if (msg.type === 'PLAYER_JOINED') {
        // Player chip added via SYNC_STATE usually, but we can handle it for responsiveness
        const chip = document.createElement('div');
        chip.id = 'pl-' + msg.playerId;
        chip.style.cssText = 'background:rgba(74,48,160,0.5);border:1px solid var(--border);border-radius:12px;padding:.4rem 1rem;font-family:Fredoka,sans-serif;font-size:1.1rem;';
        chip.textContent = msg.displayName;
        playerList.appendChild(chip);
      }

      if (msg.type === 'PLAYER_KICKED') {
        document.getElementById('pl-' + msg.playerId)?.remove();
      }

      if (msg.type === 'GAME_START') {
        lobbyScreen.classList.add('hidden');
        gameScreen.classList.remove('hidden');
      }

      if (msg.type === 'QUESTION_OPEN') {
        buzzBanner.classList.add('hidden');
        const valLabel = '$' + msg.value + (msg.isDailyDouble ? ' ★ DAILY DOUBLE' : '');
        document.getElementById('qCategory').textContent = msg.categoryTitle + ' · ' + valLabel;
        document.getElementById('qText').textContent = msg.questionText;
        questionOverlay.classList.remove('hidden');
      }

      if (msg.type === 'BUZZ_WINNER') {
        const color = playerColorMap[msg.displayName] || '#FF3D8E';
        buzzBanner.style.background = color;
        buzzBanner.style.boxShadow = `0 12px 36px ${color}80`;
        buzzName.textContent = msg.displayName + ' BUZZED IN';
        buzzBanner.classList.remove('hidden');
        highlightBuzzedPlayer(msg.displayName);
      }

      if (msg.type === 'QUESTION_CLOSED') {
        questionOverlay.classList.add('hidden');
        buzzBanner.classList.add('hidden');
        highlightBuzzedPlayer(null);
      }

      if (msg.type === 'SCORE_UPDATE') {
        gameState.scores = msg.scores || gameState.scores;
        gameState.teams = msg.teams || gameState.teams;
        renderScores();
      }

      if (msg.type === 'ROUND_ADVANCE') {
        roundNotifTitle.textContent = msg.roundTitle;
        roundNotif.classList.remove('hidden');
        setTimeout(() => roundNotif.classList.add('hidden'), 3500);
      }

      if (msg.type === 'START_FINAL_JEOPARDY') {
        questionOverlay.classList.add('hidden');
        document.getElementById('qCategory').textContent = 'FINAL JEOPARDY';
        document.getElementById('qText').textContent = 'Players are entering their wagers...';
        questionOverlay.classList.remove('hidden');
      }

      if (msg.type === 'FINAL_JEOPARDY_START') {
        document.getElementById('qText').textContent = msg.questionText;
      }

      if (msg.type === 'GAME_OVER') {
        gameState.scores = msg.scores || gameState.scores;
        gameState.teams = msg.teams || gameState.teams;
        renderScores();
        questionOverlay.classList.add('hidden');
        const winner = [...gameState.scores].sort((a, b) => b.score - a.score)[0];
        if (winner) {
          document.getElementById('qCategory').textContent = 'GAME OVER';
          document.getElementById('qText').textContent = `${winner.displayName} WINS!`;
          questionOverlay.classList.remove('hidden');
        }
      }
    }

    function applySyncState(state) {
      if (state.serverTime && state.serverTime < lastStateTime) {
        console.warn('[Presenter] Ignoring stale state sync');
        return;
      }
      lastStateTime = state.serverTime || Date.now();
      if (state.serverTime) offset = state.serverTime - Date.now();

      gameState.board = state.board;
      gameState.usedQuestions = new Set(state.usedQuestions || []);
      gameState.scores = state.scores || [];
      gameState.teams = state.teams || [];
      gameState.currentPicker = state.currentPicker;
      gameState.currentRound = state.currentRound ?? 0;
      gameState.totalRounds = state.totalRounds ?? 1;
      gameState.teamMode = state.teamMode ?? false;
      
      if (state.status === 'active' || state.status === 'final_jeopardy' || state.status === 'finished') {
        lobbyScreen.classList.add('hidden');
        gameScreen.classList.remove('hidden');
      } else {
        lobbyScreen.classList.remove('hidden');
        gameScreen.classList.add('hidden');
      }

      // Render players in lobby
      playerList.innerHTML = '';
      gameState.scores.forEach(p => {
        const chip = document.createElement('div');
        chip.id = 'pl-' + p.playerId;
        chip.style.cssText = 'background:rgba(74,48,160,0.5);border:1px solid var(--border);border-radius:12px;padding:.4rem 1rem;font-family:Fredoka,sans-serif;font-size:1.1rem;';
        chip.textContent = p.displayName;
        playerList.appendChild(chip);
      });

      renderBoard();
      renderScores();
      updateRoundBadge();

      // Restore active question overlay
      if (state.activeQuestion) {
        const aq = state.activeQuestion;
        const valLabel = '$' + aq.value + (aq.isDailyDouble ? ' ★ DAILY DOUBLE' : '');
        document.getElementById('qCategory').textContent = aq.categoryTitle + ' · ' + valLabel;
        document.getElementById('qText').textContent = aq.questionText;
        questionOverlay.classList.remove('hidden');
        // Restore buzz winner if present
        if (state.buzzWinner) {
          const color = playerColorMap[state.buzzWinner.displayName] || '#FF3D8E';
          buzzBanner.style.background = color;
          buzzBanner.style.boxShadow = `0 12px 36px ${color}80`;
          buzzName.textContent = state.buzzWinner.displayName + ' BUZZED IN';
          buzzBanner.classList.remove('hidden');
          highlightBuzzedPlayer(state.buzzWinner.displayName);
        } else {
          buzzBanner.classList.add('hidden');
          highlightBuzzedPlayer(null);
        }
      } else {
        questionOverlay.classList.add('hidden');
        buzzBanner.classList.add('hidden');
        highlightBuzzedPlayer(null);
      }
    }

    /* ── Render board ──────────────────────────────────────────────────────── */
    function renderBoard() {
      if (!gameState.board) return;
      const cats = gameState.board.categories || [];
      const numCats = cats.length;
      if (!numCats) return;
      const maxQ = Math.max(...cats.map((c) => c.questions.length));
      presenterBoard.style.gridTemplateColumns = `repeat(${numCats}, 1fr)`;
      presenterBoard.style.gridTemplateRows = `120px repeat(${maxQ}, 1fr)`;
      presenterBoard.innerHTML = '';
      // Category headers
      for (const cat of cats) {
        const h = document.createElement('div');
        h.className = 'presenter-cat-header';
        h.textContent = cat.title;
        presenterBoard.appendChild(h);
      }
      // Question rows
      let totalQ = 0, usedQ = 0;
      for (let qi = 0; qi < maxQ; qi++) {
        for (const cat of cats) {
          const q = cat.questions.sort((a, b) => a.value - b.value)[qi];
          if (!q) { presenterBoard.appendChild(document.createElement('div')); continue; }
          totalQ++;
          const used = gameState.usedQuestions.has(q.id);
          if (used) usedQ++;
          const cell = document.createElement('div');
          cell.className = 'presenter-q-cell' + (used ? ' used' : '');
          if (!used) cell.textContent = '$' + q.value;
          presenterBoard.appendChild(cell);
        }
      }
      updateCluesPill(usedQ, totalQ);
    }

    /* ── Render scores ─────────────────────────────────────────────────────── */
    function renderScores() {
      presenterScores.innerHTML = '';
      playerColorMap = {};
      const players = [...gameState.scores].sort((a, b) => b.score - a.score);
      const cols = Math.min(Math.max(players.length, 1), 6);
      presenterScores.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
      players.forEach((p, i) => {
        const color = PLAYER_COLORS[i % PLAYER_COLORS.length];
        playerColorMap[p.displayName] = color;
        const initial = (p.displayName || '?')[0].toUpperCase();
        const scoreColor = p.score < 0 ? 'var(--red)' : 'var(--gold)';
        const scoreStr = p.score < 0 ? `-$${Math.abs(p.score).toLocaleString()}` : `$${p.score.toLocaleString()}`;
        const card = document.createElement('div');
        card.className = 'presenter-player-card';
        card.style.borderColor = 'transparent';
        card.dataset.player = p.displayName;
        card.innerHTML = `
          <div class="presenter-player-avatar" style="background:${color}">${initial}</div>
          <div style="flex:1;min-width:0;">
            <div class="presenter-player-name">${p.displayName}</div>
            <div class="presenter-player-score" style="color:${scoreColor}">${scoreStr}</div>
          </div>`;
        presenterScores.appendChild(card);
      });
    }

    function highlightBuzzedPlayer(displayName) {
      document.querySelectorAll('.presenter-player-card').forEach(card => {
        const isBuzzed = card.dataset.player === displayName;
        card.classList.toggle('buzzed', isBuzzed);
        card.style.borderColor = isBuzzed ? (playerColorMap[displayName] || 'transparent') : 'transparent';
        card.style.boxShadow = isBuzzed ? `0 0 24px ${playerColorMap[displayName] || '#FF3D8E'}55` : 'none';
      });
    }

    function updateCluesPill(used, total) {
      if (cluesPill) cluesPill.textContent = `${used} OF ${total} CLUES`;
    }

    function updateRoundBadge() {
      if (roundPill) roundPill.textContent = `ROUND ${gameState.currentRound + 1} OF ${gameState.totalRounds}`;
      if (cluesPill && !cluesPill.textContent) cluesPill.textContent = '— CLUES';
    }
  </script>
</body>
</html>
