---
// Player view — phone buzzer app. No auth required for viewing; join via POST.
import '@/styles/global.css';
import { PLAYER_COOKIE, verifyPlayerToken } from '@/lib/auth';
import { db, schema } from '@/lib/db';
import { eq } from 'drizzle-orm';

const gameId = String(Astro.params.id).toUpperCase();
const gameRows = await db.select({ id: schema.games.id, status: schema.games.status })
  .from(schema.games).where(eq(schema.games.id, gameId));
if (!gameRows.length) return Astro.redirect('/join');

const token = Astro.cookies.get(PLAYER_COOKIE)?.value ?? '';
const payload = token ? verifyPlayerToken(token) : null;
const isJoined = !!(payload && payload.gameId === gameId);
const initialPlayerId = payload?.playerId ?? '';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Jeoparty — Play</title>
  <style>
    html, body { height: 100%; overflow: hidden; background: var(--bg); margin: 0; }
    #scale-root { transform-origin: top left; }
    .state-section { display: flex; flex-direction: column; gap: .75rem; padding: 1rem; }
  </style>
</head>
<body>
  <div id="scale-root" class="phone-root">

    <!-- Join form (shown if not yet joined) -->
    <div id="joinCard" class={`state-section ${isJoined ? 'hidden' : ''}`} style="min-height:100vh; justify-content:center; align-items:center;">
      <div style="text-align:center; font-family:'Anton',sans-serif; font-size:2.5rem; font-weight:700; color:var(--accent);">JEOPARTY</div>
      <div class="card grid" style="width:100%;">
        <h2 style="text-align:center;">Join Game</h2>
        <div class="join-code" style="text-align:center; font-size:3rem;">{gameId}</div>
        <input id="displayName" maxlength="64" placeholder="Your nickname" style="font-size:1.1rem;" autocomplete="nickname" />
        <button id="joinBtn" class="accent" style="font-size:1.15rem;">Join!</button>
        <p id="joinMsg" class="small" style="text-align:center; min-height:1em;"></p>
      </div>
    </div>

    <!-- Game app (shown after joining) -->
    <div id="app" class={isJoined ? '' : 'hidden'}>

      <!-- State card -->
      <div class="state-section">
        <div class="card grid">
          <div class="flex-between">
            <h2 id="stateTitle" style="font-size:1.6rem;">Lobby</h2>
            <span id="myScore" style="font-family:'Anton',sans-serif; font-size:1.4rem; color:var(--accent);"></span>
          </div>
          <p id="stateText" class="muted">Waiting for the host to start...</p>

          <!-- Countdown -->
          <div id="countdown" class="countdown hidden"></div>

          <!-- Buzz button -->
          <button id="buzzBtn" class="buzzer-btn hidden">BUZZ!</button>

          <!-- Input area (wager / answer) -->
          <div id="inputArea" class="grid hidden"></div>
        </div>

        <!-- Board (shown when it's your turn to pick) -->
        <div id="boardWrap" class="card hidden">
          <h3 style="margin-bottom:.5rem;">Pick a Question</h3>
          <div id="playerBoard" class="board-grid"></div>
        </div>

        <!-- Scores card -->
        <div class="card">
          <h3 style="margin-bottom:.5rem;">Scores</h3>
          <ul id="scoresList" class="scores"></ul>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ gameId, token: token, initialPlayerId, isJoined }}>
    // @ts-nocheck
    /* ── Scaling ───────────────────────────────────────────────────────────── */
    function scale() {
      const root = document.getElementById('scale-root');
      const tw = 390; const th = 844;
      const s = Math.min(window.innerWidth / tw, window.innerHeight / th);
      root.style.width = tw + 'px';
      root.style.height = th + 'px';
      root.style.transform = `scale(${s}) translate(-50%, -50%)`;
      root.style.left = '50%';
      root.style.top = '50%';
      root.style.position = 'absolute';
      root.style.transformOrigin = 'top left';
    }
    scale();
    window.addEventListener('resize', scale);

    /* ── State ─────────────────────────────────────────────────────────────── */
    let playerId   = initialPlayerId;
    let playerToken = token;
    let offset     = 0;
    let canBuzz    = false;
    let isMyTurn   = false;
    let finalTimer = null;
    let gameState  = { board: null, usedQuestions: new Set(), scores: [], teams: [], currentPicker: null, teamMode: false };

    const stateTitle  = document.getElementById('stateTitle');
    const stateText   = document.getElementById('stateText');
    const myScore     = document.getElementById('myScore');
    const scoresList  = document.getElementById('scoresList');
    const boardWrap   = document.getElementById('boardWrap');
    const playerBoard = document.getElementById('playerBoard');
    const buzzBtn     = document.getElementById('buzzBtn');
    const countdown   = document.getElementById('countdown');
    const inputArea   = document.getElementById('inputArea');

    /* ── Sound stubs ───────────────────────────────────────────────────────── */
    const sounds = {
      buzzerOpen()     { /* TODO: play buzzer-open.mp3 */ },
      buzzIn()         { /* TODO: play buzz-in.mp3 */ },
      correct()        { /* TODO: play correct.mp3 */ },
      wrong()          { /* TODO: play wrong.mp3 */ },
      dailyDouble()    { /* TODO: play daily-double.mp3 */ },
      finalTheme()     { /* TODO: play final-jeopardy-theme.mp3 */ },
      gameOver()       { /* TODO: play game-over.mp3 */ },
    };

    /* ── Helpers ───────────────────────────────────────────────────────────── */
    function setState(title, text = '') {
      stateTitle.textContent = title;
      stateText.textContent = text;
    }

    function updateMyScore() {
      const me = gameState.scores.find((s) => s.playerId === playerId);
      if (me) myScore.textContent = '$' + me.score;
    }

    function renderScores() {
      scoresList.innerHTML = '';
      const items = gameState.teamMode && gameState.teams.length
        ? gameState.teams.map((t) => ({ name: t.name, score: t.score })).sort((a, b) => b.score - a.score)
        : [...gameState.scores].sort((a, b) => b.score - a.score).map((s) => ({ name: s.displayName, score: s.score }));
      for (const item of items) {
        const li = document.createElement('li');
        li.innerHTML = `<span>${item.name}</span><strong>$${item.score}</strong>`;
        scoresList.appendChild(li);
      }
      updateMyScore();
    }

    function renderBoard() {
      boardWrap.classList.add('hidden');
      if (!isMyTurn || !gameState.board) return;
      const cats = gameState.board.categories || [];
      if (!cats.length) return;
      boardWrap.classList.remove('hidden');
      playerBoard.style.gridTemplateColumns = `repeat(${cats.length}, 1fr)`;
      playerBoard.innerHTML = '';
      for (const cat of cats) {
        const h = document.createElement('div');
        h.className = 'cat-header';
        h.style.fontSize = '.75rem';
        h.textContent = cat.title;
        playerBoard.appendChild(h);
      }
      const maxQ = Math.max(...cats.map((c) => c.questions.length), 0);
      for (let qi = 0; qi < maxQ; qi++) {
        for (const cat of cats) {
          const q = (cat.questions || []).sort((a, b) => a.value - b.value)[qi];
          if (!q) { playerBoard.appendChild(document.createElement('div')); continue; }
          const btn = document.createElement('button');
          btn.className = 'question-cell' + (gameState.usedQuestions.has(q.id) ? ' used secondary' : '');
          btn.style.fontSize = '1.05rem';
          btn.textContent = '$' + q.value;
          btn.disabled = gameState.usedQuestions.has(q.id);
          btn.addEventListener('click', () => ws.send(JSON.stringify({ type: 'SELECT_QUESTION', questionId: q.id })));
          playerBoard.appendChild(btn);
        }
      }
    }

    function showInput(mode) {
      inputArea.classList.remove('hidden');
      inputArea.innerHTML = '';
      if (mode === 'wager' || mode === 'dd-wager') {
        const isDd = mode === 'dd-wager';
        const myScoreVal = gameState.scores.find((s) => s.playerId === playerId)?.score ?? 0;
        const allVals = (gameState.board?.categories ?? []).flatMap((c) => c.questions.map((q) => q.value));
        const cap = isDd ? Math.max(myScoreVal, allVals.length ? Math.max(...allVals) : 0) : undefined;
        inputArea.innerHTML = `
          ${cap != null ? `<p class="small">Max wager: $${cap}</p>` : '<p class="small">Enter your wager</p>'}
          <input id="wagerInput" type="number" min="0" ${cap != null ? `max="${cap}"` : ''} placeholder="Wager amount" style="font-size:1.1rem;" />
          <button id="submitWager" class="accent">Submit Wager</button>`;
        document.getElementById('submitWager').addEventListener('click', () => {
          const wager = Math.max(0, Number(document.getElementById('wagerInput').value || 0));
          ws.send(JSON.stringify({ type: isDd ? 'DAILY_DOUBLE_WAGER' : 'FINAL_WAGER', wager }));
          inputArea.classList.add('hidden');
          if (!isDd) setState('Wager Submitted', 'Waiting for everyone...');
        });
      }
      if (mode === 'answer') {
        inputArea.innerHTML = `
          <input id="answerInput" placeholder="Type your final answer" style="font-size:1.05rem;" />
          <button id="submitAnswer" class="accent">Submit Answer</button>`;
        document.getElementById('submitAnswer').addEventListener('click', () => {
          ws.send(JSON.stringify({ type: 'FINAL_ANSWER', answer: document.getElementById('answerInput').value }));
          inputArea.classList.add('hidden');
          setState('Answer Submitted', 'Waiting for results...');
        });
      }
    }

    /* ── WebSocket ─────────────────────────────────────────────────────────── */
    let ws;
    let lastStateTime = 0;
    let pingSentAt = 0;

    function sendPing() {
      if (!ws || ws.readyState !== 1) return;
      pingSentAt = Date.now();
      ws.send(JSON.stringify({ type: 'PING', clientTime: pingSentAt }));
    }

    function connect() {
      if (!playerToken) return;
      const wsUrl = `${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.host}/ws?gameId=${encodeURIComponent(gameId)}&token=${encodeURIComponent(playerToken)}`;
      
      if (ws) { ws.onclose = null; ws.close(); }
      ws = new WebSocket(wsUrl);

      ws.addEventListener('open', () => {
        console.log('[Player] Connected to WebSocket');
        sendPing();
      });

      ws.addEventListener('close', () => { 
        setTimeout(connect, 2000); 
      });

      ws.addEventListener('message', (event) => {
        const msg = JSON.parse(event.data);

        if (msg.type === 'PONG') {
          if (msg.clientTime != null && typeof msg.clientTime === 'number') {
            offset = msg.serverTime - (msg.clientTime + Date.now()) / 2;
          } else {
            offset = msg.serverTime - Date.now();
          }
          return;
        }

        console.log('[Player] Message:', msg.type, msg);

        if (msg.type === 'SYNC_STATE' || msg.type === 'BOARD_STATE') {
          applySyncState(msg);
          return;
        }

        if (msg.type === 'GAME_START') {
          setState('Game On!', 'Watch the screen!');
          isMyTurn = false;
          renderBoard();
        }

        if (msg.type === 'ROUND_ADVANCE') {
          setState('Next Round!', msg.roundTitle);
          gameState.usedQuestions = new Set();
          renderBoard();
        }

        if (msg.type === 'QUESTION_OPEN') {
          buzzBtn.classList.add('hidden');
          countdown.classList.add('hidden');
          canBuzz = false;
          if (msg.isDailyDouble) {
            sounds.dailyDouble();
            setState('⭐ Daily Double!', msg.questionText);
            if (gameState.currentPicker === playerId) {
              showInput('dd-wager');
            } else {
              setState('⭐ Daily Double!', msg.questionText + '\nWaiting for ' + (gameState.scores.find(s => s.playerId === gameState.currentPicker)?.displayName ?? 'player') + '\'s wager...');
            }
          } else {
            setState('Question!', msg.questionText);
            inputArea.classList.add('hidden');
          }
          boardWrap.classList.add('hidden');
        }

        if (msg.type === 'BUZZER_OPEN') {
          sounds.buzzerOpen();
          canBuzz = true;
          buzzBtn.classList.remove('hidden');
          buzzBtn.classList.add('buzzer-ready');
          countdown.classList.add('hidden');
          setState('BUZZ!', 'Buzz when you know it. Earliest buzz wins after everyone has a moment to ring in.');
        }

        if (msg.type === 'BUZZ_WINNER') {
          canBuzz = false;
          buzzBtn.classList.remove('hidden', 'buzzer-ready');
          buzzBtn.classList.add('hidden');
          countdown.classList.add('hidden');
          if (msg.playerId === playerId) {
            sounds.buzzIn();
            setState("You're in! 🎤", 'Answer out loud!');
            buzzBtn.classList.add('hidden');
          } else {
            setState('🔒 Locked out', msg.displayName + ' buzzed in!');
          }
        }

        if (msg.type === 'QUESTION_RESULT') {
          if (msg.playerId === playerId) {
            if (msg.correct) {
              sounds.correct();
              setState('✓ Correct!', '+$' + Math.abs(msg.newScore - (gameState.scores.find(s => s.playerId === playerId)?.score ?? 0)));
            } else {
              sounds.wrong();
              setState('✗ Wrong', 'Wait for buzzer to reopen...');
            }
          }
          // Update local score optimistically
          const s = gameState.scores.find((s) => s.playerId === msg.playerId);
          if (s) s.score = msg.newScore;
          updateMyScore();
        }

        if (msg.type === 'QUESTION_CLOSED') {
          canBuzz = false;
          buzzBtn.classList.add('hidden');
          buzzBtn.classList.remove('buzzer-ready');
          countdown.classList.add('hidden');
          inputArea.classList.add('hidden');
          isMyTurn = !!(playerId && gameState.currentPicker === playerId);
          setState(isMyTurn ? 'Your Pick!' : 'Board', isMyTurn ? 'Tap a question to pick.' : '');
          renderBoard();
        }

        if (msg.type === 'START_FINAL_JEOPARDY') {
          sounds.finalTheme();
          setState('Final Jeopardy', 'Enter your wager!');
          showInput('wager');
        }

        if (msg.type === 'FINAL_JEOPARDY_START') {
          setState('Final Jeopardy', msg.questionText);
          inputArea.classList.add('hidden');
          showInput('answer');
          let left = 30;
          clearInterval(finalTimer);
          countdown.classList.remove('hidden');
          finalTimer = setInterval(() => {
            left--;
            countdown.textContent = left + 's';
            countdown.className = 'countdown' + (left <= 5 ? ' urgent' : '');
            if (left <= 0) { clearInterval(finalTimer); countdown.classList.add('hidden'); }
          }, 1000);
        }

        if (msg.type === 'GAME_OVER') {
          sounds.gameOver();
          clearInterval(finalTimer);
          gameState.scores = msg.scores || gameState.scores;
          gameState.teams = msg.teams || gameState.teams;
          renderScores();
          const winner = [...gameState.scores].sort((a, b) => b.score - a.score)[0];
          setState('Game Over! 🏆', winner ? winner.displayName + ' wins with $' + winner.score + '!' : 'Thanks for playing!');
          buzzBtn.classList.add('hidden');
          inputArea.classList.add('hidden');
          countdown.classList.add('hidden');
        }

        if (msg.type === 'PLAYER_KICKED' && msg.playerId === playerId) {
          setState('Kicked', 'You were removed from the game.');
          if (ws) ws.close();
        }
      });
    }

    // Heartbeat
    setInterval(() => {
      if (ws && ws.readyState === 1) sendPing();
      else if (playerToken && (!ws || ws.readyState === 3)) connect();
    }, 10000);

    function applySyncState(state) {
      if (state.serverTime && state.serverTime < lastStateTime) {
        console.warn('[Player] Ignoring stale state sync');
        return;
      }
      lastStateTime = state.serverTime || Date.now();
      if (state.serverTime) offset = state.serverTime - Date.now();

      gameState.board = state.board;
      gameState.usedQuestions = new Set(state.usedQuestions || []);
      gameState.scores = state.scores || [];
      gameState.teams = state.teams || [];
      gameState.currentPicker = state.currentPicker;
      gameState.teamMode = state.teamMode ?? false;
      isMyTurn = !!(playerId && gameState.currentPicker === playerId);

      // Status handling
      if (state.status === 'lobby') {
        setState('Lobby', 'Waiting for the host to start...');
      } else if (state.status === 'active') {
        if (!isMyTurn) setState('Watch the Screen', 'Someone else is picking.');
        else setState('Your Pick!', 'Choose a category and value.');
      } else if (state.status === 'final_jeopardy') {
        setState('Final Jeopardy', 'Pay attention to the screen!');
      }

      renderScores();
      renderBoard();
    }

    /* ── Join form ─────────────────────────────────────────────────────────── */
    document.getElementById('joinBtn').addEventListener('click', async () => {
      const name = document.getElementById('displayName').value.trim();
      const msgEl = document.getElementById('joinMsg');
      if (!name) { msgEl.textContent = 'Enter a nickname.'; msgEl.style.color = 'var(--bad)'; return; }
      const res = await fetch(`/api/games/${gameId}/join`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ displayName: name }),
      });
      if (!res.ok) {
        const json = await res.json().catch(() => ({}));
        msgEl.textContent = json.error || 'Could not join.';
        msgEl.style.color = 'var(--bad)';
        return;
      }
      const json = await res.json();
      playerToken = json.token;
      playerId = json.playerId;
      document.getElementById('joinCard').classList.add('hidden');
      document.getElementById('app').classList.remove('hidden');
      connect();
    });

    /* ── Buzz button ───────────────────────────────────────────────────────── */
    buzzBtn.addEventListener('click', () => {
      if (!canBuzz || !ws) return;
      canBuzz = false;
      buzzBtn.classList.remove('buzzer-ready');
      ws.send(JSON.stringify({ type: 'BUZZ', clientTime: Date.now() + offset }));
    });

    // Auto-connect if already joined
    if (isJoined) connect();
  </script>
</body>
</html>
