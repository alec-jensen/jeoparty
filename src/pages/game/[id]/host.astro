---
// Host controls — requires auth matching the game's host
import '@/styles/global.css';
import QRCode from 'qrcode';
import { HOST_COOKIE } from '@/lib/auth';
import { db, schema } from '@/lib/db';
import { eq, inArray } from 'drizzle-orm';

if (!Astro.locals.host) return Astro.redirect(`/?next=/game/${Astro.params.id}/host`);

const gameId = String(Astro.params.id).toUpperCase();
const gameRows = await db.select().from(schema.games).where(eq(schema.games.id, gameId));
if (!gameRows.length || gameRows[0].hostId !== Astro.locals.host.hostId) return Astro.redirect('/dashboard');

const game = gameRows[0];
const hostToken = Astro.cookies.get(HOST_COOKIE)?.value ?? '';

const roundRows = await db.select().from(schema.rounds).where(eq(schema.rounds.boardId, game.boardId)).orderBy(schema.rounds.position);
const categoryRows = roundRows.length
  ? await db.select().from(schema.categories).where(inArray(schema.categories.roundId, roundRows.map(r => r.id))).orderBy(schema.categories.position)
  : [];
const questionRows = categoryRows.length
  ? await db.select().from(schema.questions).where(inArray(schema.questions.categoryId, categoryRows.map(c => c.id))).orderBy(schema.questions.position)
  : [];
const usedRows = await db.select({ questionId: schema.usedQuestions.questionId }).from(schema.usedQuestions).where(eq(schema.usedQuestions.gameId, gameId));
const playerRows = await db.select().from(schema.players).where(eq(schema.players.gameId, gameId));
const teamRows = await db.select().from(schema.teams).where(eq(schema.teams.gameId, gameId));

const questionsByCategory = new Map();
for (const q of questionRows) {
  const list = questionsByCategory.get(q.categoryId) ?? [];
  list.push(q);
  questionsByCategory.set(q.categoryId, list);
}
const categoriesByRound = new Map();
for (const c of categoryRows) {
  const list = categoriesByRound.get(c.roundId) ?? [];
  list.push({ ...c, questions: questionsByCategory.get(c.id) ?? [] });
  categoriesByRound.set(c.roundId, list);
}
const rounds = roundRows.map(r => ({ ...r, categories: categoriesByRound.get(r.id) ?? [] }));

const joinUrl = `${Astro.url.origin}/join?code=${gameId}`;
const qrSvg = await QRCode.toString(joinUrl, { type: 'svg', color: { dark: '#f5c518', light: '#0d0a1e' }, margin: 1 });

const seed = {
  rounds,
  usedQuestionIds: usedRows.map(u => u.questionId),
  initialPlayers: playerRows.map(p => [p.id, { playerId: p.id, displayName: p.displayName, score: p.score ?? 0, teamId: p.teamId ?? null }]),
  initialTeams: teamRows.map(t => [t.id, { id: t.id, name: t.name, position: t.position, playerIds: [] }]),
  teamMode: game.teamMode ?? false,
  currentRound: game.currentRound ?? 0,
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Host — {gameId}</title>
  <style is:global>
    html, body { height: 100%; overflow: hidden; background: var(--bg); margin: 0; }
    #scale-root { 
      width: 390px; 
      height: 844px; 
      background: var(--bg); 
      position: absolute; 
      left: 50%; 
      top: 50%; 
      transform-origin: center center;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    
    /* Premium UI Components from Mockup */
    .app-bar { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px 10px; border-bottom: 1px solid var(--line); flex-shrink: 0; }
    .logo { font-family: 'Anton', sans-serif; font-size: 24px; color: var(--gold); letter-spacing: 0.04em; line-height: 1; display: flex; align-items: center; gap: 8px; }
    .badge { font-family: 'Space Grotesk', sans-serif; font-size: 10px; color: var(--dim); letter-spacing: 0.22em; padding: 4px 8px; background: var(--bg2); border-radius: 4px; font-weight: 700; text-transform: uppercase; }
    .game-code { font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--dim); letter-spacing: 0.18em; font-weight: 700; }
    .menu-btn { width: 34px; height: 34px; border-radius: 10px; background: var(--bg2); color: var(--ink); font-size: 18px; border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; cursor: pointer; }
    
    .status-bar { display: flex; align-items: center; justify-content: space-between; padding: 10px 18px; border-bottom: 1px solid var(--line); background: var(--bg2); flex-shrink: 0; }
    .round-info { font-family: 'Anton', sans-serif; font-size: 13px; letter-spacing: 0.12em; color: var(--ink); text-transform: uppercase; }
    
    .scroll-area { flex: 1; overflow-y: auto; padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }
    
    .clue-card { background: var(--bg2); border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; position: relative; }
    .clue-cat { font-family: 'Anton', sans-serif; font-size: 14px; letter-spacing: 0.06em; color: var(--ink); text-transform: uppercase; }
    .clue-val { font-family: 'Anton', sans-serif; font-size: 18px; color: var(--gold); position: absolute; top: 14px; right: 16px; }
    .label { font-size: 9px; color: var(--dim); letter-spacing: 0.22em; font-family: 'Space Grotesk', sans-serif; font-weight: 700; margin-bottom: 4px; text-transform: uppercase; }
    .clue-text { font-family: 'Anton', sans-serif; font-size: 18px; line-height: 1.2; letter-spacing: 0.01em; color: var(--ink); margin-top: 4px; }
    
    .answer-row { margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--line); display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .answer-text { font-family: 'Anton', sans-serif; font-size: 18px; color: var(--mint); letter-spacing: 0.04em; }
    
    .judge-panel { background: var(--bg2); border-radius: 12px; padding: 14px 14px 12px; border: 2px solid transparent; transition: all 0.3s ease; }
    .judge-active { border-color: var(--magenta); box-shadow: 0 0 32px rgba(255, 61, 142, 0.2); }
    
    .buzz-status { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .buzz-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--magenta); box-shadow: 0 0 10px var(--magenta); animation: jp-pulse 1.2s infinite; }
    .buzz-label { font-size: 10px; color: var(--dim); letter-spacing: 0.22em; font-weight: 700; text-transform: uppercase; }
    
    .judge-target { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
    .avatar-large { width: 48px; height: 48px; border-radius: 12px; background: var(--magenta); display: flex; align-items: center; justify-content: center; font-size: 26px; color: #0E0B22; font-weight: 800; }
    .judge-name { font-family: 'Anton', sans-serif; font-size: 22px; letter-spacing: 0.04em; color: var(--ink); line-height: 1.1; }
    
    .judge-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .btn-judge { border: none; border-radius: 10px; cursor: pointer; font-family: 'Anton', sans-serif; font-size: 18px; letter-spacing: 0.06em; padding: 14px 0; color: #fff; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .btn-wrong { background: var(--red); }
    .btn-correct { background: var(--mint); color: #0E0B22; }
    
    .queue-row { margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--line); display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .queue-chip { font-family: 'Anton', sans-serif; font-size: 11px; letter-spacing: 0.06em; color: var(--ink); background: var(--bg); padding: 4px 8px; border-radius: 999px; border: 1px solid var(--line2); }
    
    /* Player list — matches mock/project/jp-host.jsx PlayersList + MiniStep */
    .player-row { display: flex; align-items: center; gap: 10px; background: #120D2E; border: 1px solid transparent; padding: 8px 10px; border-radius: 10px; transition: background 0.2s ease, border-color 0.2s ease; }
    .row-highlight { background: var(--bg3); }
    .player-rank { font-family: 'Anton', sans-serif; font-size: 12px; color: var(--dim); width: 12px; flex-shrink: 0; }
    .avatar-small { width: 26px; height: 26px; border-radius: 6px; background: var(--gold); display: flex; align-items: center; justify-content: center; font-size: 13px; color: #0E0B22; font-weight: 700; flex-shrink: 0; }
    .player-name-row { flex: 1; min-width: 0; font-family: 'Anton', sans-serif; font-size: 14px; letter-spacing: 0.04em; color: var(--ink); }
    /* Grid keeps − / $ / + on one optical row (Anton score vs square buttons). */
    .player-score-group {
      display: grid;
      grid-template-columns: 22px minmax(52px, max-content) 22px;
      align-items: center;
      column-gap: 4px;
      flex-shrink: 0;
    }
    .score-display {
      font-family: 'Anton', sans-serif;
      font-size: 14px;
      line-height: 1;
      color: var(--gold);
      min-width: 52px;
      text-align: right;
      margin: 0;
      padding: 0;
      justify-self: end;
      align-self: center;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      min-height: 22px;
      font-variant-numeric: tabular-nums;
    }
    .score-display.negative { color: var(--red); }
    .mini-stepper { width: 28px; height: 28px; border-radius: 6px; background: var(--bg); color: var(--ink); font-size: 16px; border: 1.5px solid var(--line); display: flex; align-items: center; justify-content: center; cursor: pointer; font-weight: 700; transition: all 0.1s ease; }
    .player-row .mini-stepper {
      width: 22px;
      height: 22px;
      min-width: 22px;
      min-height: 22px;
      border-radius: 5px;
      font-size: 13px;
      border-width: 1px;
      padding: 0;
      margin: 0;
      font-family: 'Space Grotesk', system-ui, sans-serif;
      font-weight: 600;
      line-height: 1;
      letter-spacing: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      justify-self: center;
      align-self: center;
    }
    .mini-stepper:active { transform: scale(0.9); background: var(--bg2); }
    
    .tab-bar { display: none; }
    
    /* Reveal button in clue card */
    .btn-reveal { background: var(--bg3); border: 1.5px solid var(--line); border-radius: 8px; color: var(--ink); font-family: 'Space Grotesk', sans-serif; font-size: 11px; font-weight: 700; padding: 8px 12px; display: flex; align-items: center; gap: 6px; cursor: pointer; text-transform: uppercase; }
    
    .judging-result-info { font-size: 11px; color: var(--dim); text-align: center; margin-top: 10px; }
    
    .player-list-header { display: flex; align-items: center; justify-content: space-between; margin: 0 0 8px; padding: 0 2px; }
    .player-header-label { font-size: 10px; color: var(--dim); letter-spacing: 0.22em; font-weight: 700; text-transform: uppercase; }
    .player-list-hint { letter-spacing: 0.04em; font-weight: 500; text-transform: none; }
    .players-container { display: flex; flex-direction: column; gap: 6px; }

    /* Modals */
    .modal-overlay { position: fixed; inset: 0; background: rgba(14, 11, 34, 0.95); backdrop-filter: blur(10px); z-index: 1000; padding: 20px; display: flex; flex-direction: column; }
    .board-grid-modal { display: grid; gap: 6px; flex: 1; overflow: auto; grid-auto-rows: 1fr; margin-top: 20px; }
    
    .btn-close-modal { position: absolute; top: 16px; right: 16px; width: 32px; height: 32px; border-radius: 50%; background: var(--bg3); border: 1px solid var(--line); color: var(--ink); display: flex; align-items: center; justify-content: center; cursor: pointer; }
  </style>
</head>
<body>
  <div id="scale-root">
    
    <!-- App Bar -->
    <header class="app-bar">
      <div class="logo">JEOPARTY<span class="badge">HOST</span></div>
      <div style="display: flex; align-items: center; gap: 10px;">
        <span class="game-code" id="gameCodeDisplay">{gameId}</span>
        <button class="menu-btn" id="menuBtn">⋯</button>
      </div>
    </header>

    <!-- Round Bar -->
    <div class="status-bar">
      <div style="display: flex; align-items: center;">
        <span class="round-info" id="roundInfo">ROUND 1 · 0/0</span>
        {seed.teamMode && <span class="teams-badge">TEAMS</span>}
      </div>
      <div style="display: flex; gap: 6px;">
        <button class="mini-stepper" style="width: auto; padding: 0 8px; height: 26px; font-size: 10px; letter-spacing: 0.1em;" id="showBoardBtn">BOARD</button>
        <button class="mini-stepper" style="width: auto; padding: 0 8px; height: 26px; font-size: 10px; letter-spacing: 0.1em;" id="nextRoundBtn">NEXT →</button>
      </div>
    </div>

    <!-- Main Content Area -->
    <main class="scroll-area" id="mainContent">
      
      <!-- Clue Card -->
      <div class="clue-card" id="clueCard">
        <div class="clue-val" id="clueValueDisplay">$0</div>
        <div class="clue-cat" id="clueCatDisplay">Lobby</div>
        <div style="height: 1px; background: var(--line); margin: 8px 0;"></div>
        <div class="label">CLUE</div>
        <div class="clue-text" id="clueTextDisplay">Waiting for players to join...</div>
        
        <div id="answerSection" class="hidden">
          <div class="answer-row">
            <div style="min-width: 0; flex: 1;">
              <div class="label">ANSWER</div>
              <div class="answer-text" id="answerTextDisplay">...</div>
            </div>
            <button class="btn-reveal" id="revealBtn">
              <span>📺</span> REVEAL ON TV
            </button>
          </div>
        </div>
      </div>

      <div id="skipClueWrap" class="hidden" style="margin-top: 8px;">
        <button type="button" class="btn-reveal" id="skipClueBtn" style="width: 100%; justify-content: center;">Skip clue (no buzz)</button>
      </div>

      <!-- Judging Panel -->
      <div class="judge-panel hidden" id="judgePanel">
        <div class="buzz-status">
          <div class="buzz-dot"></div>
          <div class="buzz-label">BUZZED IN · <span id="buzzTimeDisplay">0.42s</span></div>
        </div>
        
        <div class="judge-target">
          <div class="avatar-large" id="judgeAvatar">✦</div>
          <div style="flex: 1; min-width: 0;">
            <div class="judge-name" id="judgeNameDisplay">PLAYER</div>
          </div>
        </div>

        <div class="judge-actions">
          <button class="btn-judge btn-wrong" id="btnJudgeWrong">✕ WRONG</button>
          <button class="btn-judge btn-correct" id="btnJudgeCorrect">✓ CORRECT</button>
        </div>
        <div class="judging-result-info" id="judgeRewardNote">+ $0 → PLAYER</div>

        <div class="queue-row" id="buzzQueueRow" style="display: none;">
          <div class="label" style="margin-bottom: 0; margin-right: 8px;">QUEUE</div>
          <div id="queueChips" style="display: flex; gap: 6px;"></div>
        </div>
      </div>

      <!-- Start Game CTA (Lobby only) -->
      <div id="lobbyCTA" class="clue-card" style="text-align: center; border-color: var(--gold);">
        <!-- Team mode toggle (changeable while in lobby) -->
        <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 12px; font-size: 11px; letter-spacing: 0.12em; color: var(--dim);">
          <button id="lobbyModeSolo" class="mini-stepper" style="padding: 0 10px; height: 28px; font-size: 11px;">SOLO</button>
          <button id="lobbyModeTeams" class="mini-stepper" style="padding: 0 10px; height: 28px; font-size: 11px;">TEAMS</button>
          <div id="lobbyTeamCount" style="display: none; align-items: center; gap: 6px;">
            <button id="lobbyTeamMinus" class="mini-stepper" style="width: 28px; height: 28px; padding: 0;">−</button>
            <span id="lobbyTeamN" style="font-family: 'Anton', sans-serif; font-size: 18px; color: var(--ink); min-width: 28px; text-align: center;">2</span>
            <button id="lobbyTeamPlus" class="mini-stepper" style="width: 28px; height: 28px; padding: 0;">+</button>
            <span style="font-size: 10px; letter-spacing: 0.1em;">TEAMS</span>
          </div>
        </div>
        <button id="startGameBtn" class="btn-judge btn-correct" style="width: 100%; margin-bottom: 12px;">
          ▶ START GAME
        </button>
        <div class="label" style="margin: 0;">Game code: <span style="color: var(--ink);">{gameId}</span></div>
      </div>

      <!-- Players List -->
      <div id="listSection">
        <div class="player-list-header">
          <div class="player-header-label" id="listTitleDisplay">PLAYERS · 0</div>
          <div class="player-header-label player-list-hint">tap ± to adjust</div>
        </div>
        <div id="playersContainer" class="players-container">
          <!-- Players injected here -->
        </div>
      </div>
    </main>


    <!-- Modals -->
    <div id="boardModal" class="modal-overlay hidden">
      <button class="btn-close-modal" id="closeBoardModal">✕</button>
      <div style="font-family: 'Anton', sans-serif; font-size: 24px; color: var(--gold); text-align: center;">THE BOARD</div>
      <div class="board-grid-modal" id="boardGrid"></div>
    </div>

    <div id="menuOverlay" class="modal-overlay hidden" style="justify-content: center; align-items: center; gap: 12px;">
      <button class="btn-close-modal" id="closeMenuOverlay">✕</button>
      <button class="mini-stepper" style="width: 200px; height: 50px; font-size: 14px;" id="menuPresenter">📺 Presenter View</button>
      <button class="mini-stepper" style="width: 200px; height: 50px; font-size: 14px;" id="menuFinal">🏁 Final Jeopardy</button>
      <button class="mini-stepper" style="width: 200px; height: 50px; font-size: 14px; color: var(--red);" id="menuEnd">■ End Game</button>
    </div>

    <!-- Final Jeopardy: host judges + reveals each response -->
    <div id="finalModal" class="modal-overlay hidden" style="flex-direction: column; gap: 14px; overflow-y: auto;">
      <button class="btn-close-modal" id="closeFinalModal">✕</button>
      <div style="font-family: 'Anton', sans-serif; font-size: 24px; color: var(--gold); text-align: center;">FINAL JEOPARTY · RESPONSES</div>
      <div id="finalClueBox" style="background: var(--bg2); border: 1px solid var(--line); border-radius: 10px; padding: 14px 18px; max-width: 720px; margin: 0 auto;">
        <div id="finalCatLabel" style="font-size: 11px; color: var(--dim); letter-spacing: 0.22em;"></div>
        <div id="finalQText" style="font-family: 'Anton', sans-serif; font-size: 22px; margin-top: 8px;"></div>
        <div id="finalCorrect" style="font-size: 13px; color: var(--mint); margin-top: 8px;"></div>
      </div>
      <div id="finalResponseList" style="display: flex; flex-direction: column; gap: 10px; max-width: 720px; width: 100%; margin: 0 auto;"></div>
      <div style="font-size: 11px; color: var(--dim); text-align: center; max-width: 540px; margin: 0 auto;">
        Judge each response, then reveal them in order — incorrect first, correct last — for maximum suspense.
      </div>
    </div>

  </div>

  <script is:inline define:vars={{ gameId, hostToken, seed }}>
    // @ts-nocheck
    const rounds       = seed.rounds;
    const players      = new Map(seed.initialPlayers);
    let currentRound   = seed.currentRound;
    let usedSet        = new Set(seed.usedQuestionIds);
    let openQuestion   = null;
    let buzzWinnerId   = null;
    let lastStateTime  = 0;

    function formatDollars(n) {
      return n < 0 ? `-$${Math.abs(n).toLocaleString()}` : `$${n.toLocaleString()}`;
    }

    function answerTextForOpenQuestion() {
      if (!openQuestion) return '';
      for (const r of rounds) {
        for (const c of r.categories) {
          const q = c.questions.find((x) => x.id === openQuestion.questionId);
          if (q?.answer) return q.answer;
        }
      }
      return '';
    }

    /* ── Scaling ───────────────────────────────────────────────────────────── */
    function scale() {
      const root = document.getElementById('scale-root');
      const tw = 390; const th = 844;
      const s = Math.min(window.innerWidth / tw, window.innerHeight / th);
      root.style.width = tw + 'px';
      root.style.height = th + 'px';
      root.style.transform = `translate(-50%, -50%) scale(${s})`;
    }
    scale();
    window.addEventListener('resize', scale);

    /* ── WebSocket ──────────────────────────────────────────────────────── */
    let ws;
    function sendPing() {
      if (!ws || ws.readyState !== 1) return;
      const t = Date.now();
      ws.send(JSON.stringify({ type: 'PING', clientTime: t }));
    }
    function connect() {
      const wsUrl = `${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.host}/ws?gameId=${encodeURIComponent(gameId)}&token=${encodeURIComponent(hostToken)}`;
      if (ws) { ws.onclose = null; ws.close(); }
      ws = new WebSocket(wsUrl);
      ws.addEventListener('open', () => sendPing());
      ws.addEventListener('close', () => setTimeout(connect, 2000));
      ws.addEventListener('message', onMessage);
    }
    connect();

    setInterval(() => { sendPing(); }, 10000);

    function onMessage(event) {
      const msg = JSON.parse(event.data);
      if (msg.type === 'PONG') return;
      if (msg.type === 'SYNC_STATE' || msg.type === 'BOARD_STATE') {
        applySyncState(msg);
      } else if (msg.type === 'SCORE_UPDATE') {
        (msg.scores || []).forEach((s) => players.set(s.playerId, s));
        renderPlayerList();
      } else if (msg.type === 'BUZZ_WINNER') {
        renderJudging(msg);
      } else if (msg.type === 'QUESTION_CLOSED') {
        openQuestion = null;
        buzzWinnerId = null;
        document.getElementById('skipClueWrap').classList.add('hidden'); // no clue active
        updateClueCard();
        document.getElementById('judgePanel').classList.add('hidden');
        document.getElementById('judgePanel').classList.remove('judge-active');
        renderPlayerList();
      } else if (msg.type === 'QUESTION_OPEN') {
        buzzWinnerId = null;
        openQuestion = msg;
        document.getElementById('judgePanel').classList.add('hidden');
        document.getElementById('judgePanel').classList.remove('judge-active');
        // Skip is always available — host needs it for "no winner, same picker again"
        document.getElementById('skipClueWrap').classList.remove('hidden');
        updateClueCard();
        renderPlayerList();
      } else if (msg.type === 'GAME_OVER') {
        showGameOverOverlay(msg);
      } else if (msg.type === 'FINAL_JEOPARDY_REVEAL') {
        showFinalModal(msg);
      } else if (msg.type === 'FINAL_RESPONSE_REVEAL') {
        // Reflect newly-revealed state in the modal if open
        finalState.revealed[msg.playerId] = true;
        renderFinalResponses();
      }
    }

    function showGameOverOverlay(msg) {
      let overlay = document.getElementById('gameOverOverlay');
      if (!overlay) {
        overlay = document.createElement('div');
        overlay.id = 'gameOverOverlay';
        overlay.style.cssText = 'position:fixed;inset:0;background:rgba(14,11,34,0.95);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:200;backdrop-filter:blur(8px);text-align:center;padding:2rem;';
        document.body.appendChild(overlay);
      }
      const winners = (msg.scores || []).slice().sort((a, b) => b.score - a.score);
      const winner = winners[0];
      overlay.innerHTML = `
        <div style="font-family:'Anton',sans-serif;font-size:1.4rem;color:var(--dim);letter-spacing:0.32em;">GAME OVER</div>
        <div style="font-family:'Anton',sans-serif;font-size:5rem;color:var(--gold);letter-spacing:0.04em;margin-top:0.5rem;">${winner ? winner.displayName.toUpperCase() + ' WINS' : 'NO WINNER'}</div>
        ${winner ? `<div style="font-family:'Anton',sans-serif;font-size:2rem;color:var(--ink);margin-top:0.5rem;">$${(winner.score || 0).toLocaleString()}</div>` : ''}
        <button id="hostHomeBtn" style="margin-top:2rem;font-family:'Anton',sans-serif;font-size:1.3rem;background:var(--gold);color:#0E0B22;border:none;padding:1rem 2rem;border-radius:999px;cursor:pointer;letter-spacing:0.08em;">← BACK TO DASHBOARD</button>
      `;
      document.getElementById('hostHomeBtn').onclick = () => { location.href = '/dashboard'; };
    }

    function applySyncState(state) {
      if (state.serverTime && state.serverTime < lastStateTime) return;
      lastStateTime = state.serverTime || Date.now();

      if (state.scores) state.scores.forEach(s => players.set(s.playerId, s));
      if (state.usedQuestions) usedSet = new Set(state.usedQuestions);
      if (state.currentRound != null) currentRound = state.currentRound;

      // Update basic info
      const totalQ = rounds[currentRound]?.categories.reduce((s, c) => s + c.questions.length, 0) || 0;
      document.getElementById('roundInfo').textContent = `ROUND ${currentRound + 1} · ${usedSet.size}/${totalQ}`;
      document.getElementById('lobbyCTA').classList.toggle('hidden', state.status !== 'lobby');

      // Sync team config from server
      if (typeof state.teamMode === 'boolean') {
        lobbyConfig.teamMode = state.teamMode;
        lobbyConfig.numTeams = (state.teams || []).length || lobbyConfig.numTeams;
        applyLobbyConfigUI();
      }
      
      renderPlayerList();
      renderBoard();
      updateClueCard();
    }

    function updateClueCard() {
      const card = document.getElementById('clueCard');
      const cat = document.getElementById('clueCatDisplay');
      const val = document.getElementById('clueValueDisplay');
      const text = document.getElementById('clueTextDisplay');
      const ansSec = document.getElementById('answerSection');
      const ansTxt = document.getElementById('answerTextDisplay');

      if (!openQuestion) {
        cat.textContent = 'Lobby';
        val.textContent = '$0';
        text.textContent = 'Waiting for players to join...';
        ansSec.classList.add('hidden');
        document.getElementById('skipClueWrap').classList.add('hidden');
        return;
      }

      cat.textContent = openQuestion.isDailyDouble
        ? `★ DAILY DOUBLE · ${openQuestion.categoryTitle}`
        : openQuestion.categoryTitle;
      val.textContent = `$${openQuestion.value}`;
      text.textContent = openQuestion.questionText;
      // Highlight the card border for Daily Double
      card.style.borderColor = openQuestion.isDailyDouble ? 'var(--magenta)' : '';
      card.style.boxShadow = openQuestion.isDailyDouble ? '0 0 24px rgba(255,61,142,0.35)' : '';

      // Find answer
      let ans = answerTextForOpenQuestion() || '...';
      ansTxt.textContent = `WHAT IS ${ans.toUpperCase()}?`;
      ansSec.classList.remove('hidden');
    }

    function renderJudging(buzz) {
      buzzWinnerId = buzz.playerId;
      const p = document.getElementById('judgePanel');
      p.classList.remove('hidden');
      p.classList.add('judge-active');
      document.getElementById('judgeNameDisplay').textContent = buzz.displayName;
      document.getElementById('buzzTimeDisplay').textContent =
        buzz.time != null && Number.isFinite(Number(buzz.time)) ? `${Number(buzz.time)}s` : '—';
      document.getElementById('judgeRewardNote').textContent = `+ $${openQuestion?.value || 0} → ${buzz.displayName}`;

      const avatar = document.getElementById('judgeAvatar');
      avatar.style.background = getAvatarColor(buzz.playerId);
      avatar.textContent = getAvatarGlyph(buzz.playerId);

      // Re-bind buttons
      const btnC = document.getElementById('btnJudgeCorrect');
      const btnW = document.getElementById('btnJudgeWrong');
      btnC.onclick = () => ws.send(JSON.stringify({ type: 'JUDGE', playerId: buzz.playerId, correct: true }));
      btnW.onclick = () => ws.send(JSON.stringify({ type: 'JUDGE', playerId: buzz.playerId, correct: false }));
      renderPlayerList();
    }

    function renderPlayerList() {
      const container = document.getElementById('playersContainer');
      container.innerHTML = '';
      const sorted = [...players.values()].sort((a,b) => b.score - a.score);
      document.getElementById('listTitleDisplay').textContent = `PLAYERS · ${players.size}`;

      sorted.forEach((p, i) => {
        const accent = getAvatarColor(p.playerId);
        const isBuzzed = buzzWinnerId === p.playerId;
        const row = document.createElement('div');
        row.className = `player-row${isBuzzed ? ' row-highlight' : ''}`;
        if (isBuzzed) row.style.border = `1px solid ${accent}`;
        else row.style.border = '';
        const scoreClass = p.score < 0 ? 'score-display negative' : 'score-display';
        row.innerHTML = `
          <div class="player-rank">${i + 1}</div>
          <div class="avatar-small" style="background: ${accent}">${getAvatarGlyph(p.playerId)}</div>
          <div class="player-name-row">${(p.displayName || 'PLAYER').toUpperCase()}</div>
          <div class="player-score-group">
            <button type="button" class="mini-stepper minus" data-id="${p.playerId}">−</button>
            <div class="${scoreClass}">${formatDollars(p.score)}</div>
            <button type="button" class="mini-stepper plus" data-id="${p.playerId}">+</button>
          </div>
        `;
        container.appendChild(row);
      });

      container.querySelectorAll('.mini-stepper').forEach(btn => {
        btn.onclick = () => {
          const id = btn.dataset.id;
          const p = players.get(id);
          const val = btn.classList.contains('plus') ? 200 : -200;
          ws.send(JSON.stringify({ type: 'ADJUST_SCORE', playerId: id, score: p.score + val }));
        };
      });
    }

    function renderBoard() {
      const grid = document.getElementById('boardGrid');
      grid.innerHTML = '';
      const cats = rounds[currentRound]?.categories || [];
      grid.style.gridTemplateColumns = `repeat(${cats.length}, 1fr)`;

      cats.forEach(c => {
        const h = document.createElement('div');
        h.className = 'badge';
        h.style.background = 'var(--bg3)';
        h.style.textAlign = 'center';
        h.style.fontSize = '8px';
        h.style.height = '40px';
        h.style.display = 'flex';
        h.style.alignItems = 'center';
        h.style.justifyContent = 'center';
        h.textContent = c.title;
        grid.appendChild(h);
      });

      const maxQ = Math.max(...cats.map(c => c.questions.length), 0);
      for(let i=0; i<maxQ; i++) {
        cats.forEach(c => {
          const q = c.questions.sort((a,b) => a.value - b.value)[i];
          const cell = document.createElement('div');
          cell.style.borderRadius = '8px';
          cell.style.background = 'var(--bg4)';
          cell.style.position = 'relative';
          cell.style.display = 'flex';
          cell.style.flexDirection = 'column';
          cell.style.alignItems = 'center';
          cell.style.justifyContent = 'center';
          cell.style.fontFamily = 'Anton';
          cell.style.fontSize = '18px';
          cell.style.color = 'var(--gold)';
          cell.style.border = '1px solid var(--line)';
          cell.style.minHeight = '54px';
          cell.style.cursor = q && !usedSet.has(q.id) ? 'pointer' : 'default';
          if (!q || usedSet.has(q.id)) {
            cell.style.opacity = '0.18';
            cell.textContent = q ? `$${q.value}` : '';
          } else {
            cell.innerHTML = `<div>$${q.value}</div>` + (q.isDailyDouble
              ? `<div style="font-size: 9px; letter-spacing: 0.18em; color: var(--magenta); margin-top: 2px;">★ DAILY DOUBLE</div>`
              : '');
            if (q.isDailyDouble) {
              cell.style.borderColor = 'var(--magenta)';
              cell.style.boxShadow = '0 0 12px rgba(255,61,142,0.25)';
            }
            cell.onclick = () => {
              ws.send(JSON.stringify({ type: 'OPEN_QUESTION', questionId: q.id }));
              document.getElementById('boardModal').classList.add('hidden');
            };
          }
          grid.appendChild(cell);
        });
      }
    }

    function getAvatarColor(id) {
      const colors = ['#FFC83D', '#FF3D8E', '#5EEBC1', '#7C5CFF', '#FF5A5A', '#5BA9FF'];
      return colors[id.split('').reduce((a,c) => a+c.charCodeAt(0), 0) % colors.length];
    }
    function getAvatarGlyph(id) {
      const glyphs = ['◆', '✦', '▲', '●', '■', '◑'];
      return glyphs[id.split('').reduce((a,c) => a+c.charCodeAt(0), 0) % glyphs.length];
    }

    // Header controls
    document.getElementById('showBoardBtn').onclick = () => document.getElementById('boardModal').classList.remove('hidden');
    document.getElementById('closeBoardModal').onclick = () => document.getElementById('boardModal').classList.add('hidden');
    document.getElementById('menuBtn').onclick = () => document.getElementById('menuOverlay').classList.remove('hidden');
    document.getElementById('closeMenuOverlay').onclick = () => document.getElementById('menuOverlay').classList.add('hidden');
    document.getElementById('startGameBtn').onclick = () => ws.send(JSON.stringify({ type: 'GAME_START' }));
    document.getElementById('nextRoundBtn').onclick = () => ws.send(JSON.stringify({ type: 'ADVANCE_ROUND' }));
    document.getElementById('revealBtn').onclick = () => ws.send(JSON.stringify({ type: 'REVEAL_QUESTION' }));
    document.getElementById('skipClueBtn').onclick = () => ws.send(JSON.stringify({ type: 'SKIP_QUESTION' }));
    document.getElementById('menuPresenter').onclick = () => window.open(`/game/${gameId}`, '_blank');
    document.getElementById('menuEnd').onclick = () => { if(confirm('End Game?')) ws.send(JSON.stringify({ type: 'END_GAME' })); };
    document.getElementById('menuFinal').onclick = () => {
      if (confirm('Start Final Jeopardy?')) ws.send(JSON.stringify({ type: 'START_FINAL_JEOPARDY' }));
      document.getElementById('menuOverlay').classList.add('hidden');
    };
    document.getElementById('closeFinalModal').onclick = () => document.getElementById('finalModal').classList.add('hidden');

    /* ── Lobby team config ───────────────────────────────────────────────── */
    let lobbyConfig = { teamMode: false, numTeams: 2 };
    function applyLobbyConfigUI() {
      const teams = lobbyConfig.teamMode;
      document.getElementById('lobbyModeSolo').classList.toggle('active', !teams);
      document.getElementById('lobbyModeTeams').classList.toggle('active', teams);
      const tc = document.getElementById('lobbyTeamCount');
      tc.style.display = teams ? 'flex' : 'none';
      document.getElementById('lobbyTeamN').textContent = String(lobbyConfig.numTeams);
    }
    function sendLobbyConfig() {
      ws.send(JSON.stringify({
        type: 'SET_TEAM_CONFIG',
        teamMode: lobbyConfig.teamMode,
        numTeams: lobbyConfig.numTeams,
      }));
    }
    document.getElementById('lobbyModeSolo').onclick = () => {
      lobbyConfig.teamMode = false; applyLobbyConfigUI(); sendLobbyConfig();
    };
    document.getElementById('lobbyModeTeams').onclick = () => {
      lobbyConfig.teamMode = true; applyLobbyConfigUI(); sendLobbyConfig();
    };
    document.getElementById('lobbyTeamMinus').onclick = () => {
      lobbyConfig.numTeams = Math.max(2, lobbyConfig.numTeams - 1); applyLobbyConfigUI(); sendLobbyConfig();
    };
    document.getElementById('lobbyTeamPlus').onclick = () => {
      lobbyConfig.numTeams = Math.min(8, lobbyConfig.numTeams + 1); applyLobbyConfigUI(); sendLobbyConfig();
    };
    applyLobbyConfigUI();

    /* ── Final Jeopardy reveal modal ────────────────────────────────────── */
    let finalState = { results: [], judgments: {}, revealed: {} };
    function showFinalModal(msg) {
      finalState = {
        results: msg.results || [],
        judgments: {},
        revealed: {},
        category: msg.category || '',
        questionText: msg.questionText || '',
        correctAnswer: msg.correctAnswer || '',
      };
      document.getElementById('finalCatLabel').textContent = finalState.category ? `FINAL JEOPARTY · ${finalState.category.toUpperCase()}` : 'FINAL JEOPARTY';
      document.getElementById('finalQText').textContent = finalState.questionText;
      document.getElementById('finalCorrect').textContent = finalState.correctAnswer ? `Answer: ${finalState.correctAnswer}` : '';
      renderFinalResponses();
      document.getElementById('finalModal').classList.remove('hidden');
    }
    function renderFinalResponses() {
      const list = document.getElementById('finalResponseList');
      list.innerHTML = '';
      finalState.results.forEach((r) => {
        const j = finalState.judgments[r.playerId];
        const revealed = !!finalState.revealed[r.playerId];
        const row = document.createElement('div');
        row.style.cssText = 'background: var(--bg2); border: 1px solid var(--line); border-radius: 12px; padding: 14px 18px; display: flex; flex-direction: column; gap: 10px;';
        const judgedColor = j === true ? 'var(--mint)' : j === false ? 'var(--red)' : 'var(--ink)';
        row.innerHTML = `
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <div style="font-family: 'Anton', sans-serif; font-size: 18px; color: ${judgedColor};">${r.displayName.toUpperCase()}</div>
              <div style="font-size: 13px; color: var(--dim);">Wager: $${(r.wager || 0).toLocaleString()}</div>
            </div>
            <div style="font-size: 11px; letter-spacing: 0.18em; color: var(--dim);">${revealed ? 'REVEALED ✓' : j === true ? 'CORRECT' : j === false ? 'WRONG' : 'PENDING'}</div>
          </div>
          <div style="font-family: 'Space Grotesk', sans-serif; font-size: 16px; color: var(--ink); background: var(--bg); border-radius: 8px; padding: 10px 14px; min-height: 36px;">
            ${(r.answer || '— no response —').replace(/</g, '&lt;')}
          </div>
          <div style="display: flex; gap: 8px;">
            <button data-act="wrong" data-pid="${r.playerId}" ${revealed ? 'disabled' : ''} style="flex:1; padding: 10px; background: ${j === false ? 'var(--red)' : 'transparent'}; color: ${j === false ? '#0E0B22' : 'var(--red)'}; border: 1.5px solid var(--red); border-radius: 8px; font-family: 'Anton', sans-serif; letter-spacing: 0.1em; cursor: pointer;">✕ WRONG</button>
            <button data-act="right" data-pid="${r.playerId}" ${revealed ? 'disabled' : ''} style="flex:1; padding: 10px; background: ${j === true ? 'var(--mint)' : 'transparent'}; color: ${j === true ? '#0E0B22' : 'var(--mint)'}; border: 1.5px solid var(--mint); border-radius: 8px; font-family: 'Anton', sans-serif; letter-spacing: 0.1em; cursor: pointer;">✓ CORRECT</button>
            <button data-act="reveal" data-pid="${r.playerId}" ${j === undefined || revealed ? 'disabled' : ''} style="flex:1.4; padding: 10px; background: var(--gold); color: #0E0B22; border: none; border-radius: 8px; font-family: 'Anton', sans-serif; letter-spacing: 0.1em; cursor: pointer; opacity: ${j === undefined || revealed ? 0.4 : 1};">REVEAL →</button>
          </div>
        `;
        list.appendChild(row);
      });
      list.querySelectorAll('button[data-act]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const pid = btn.dataset.pid;
          const act = btn.dataset.act;
          if (act === 'wrong' || act === 'right') {
            finalState.judgments[pid] = act === 'right';
            ws.send(JSON.stringify({ type: 'JUDGE_FINAL', playerId: pid, correct: act === 'right' }));
            renderFinalResponses();
          } else if (act === 'reveal') {
            finalState.revealed[pid] = true;
            ws.send(JSON.stringify({ type: 'REVEAL_FINAL_RESPONSE', playerId: pid }));
            renderFinalResponses();
          }
        });
      });
    }

  </script>
</body>
</html>
