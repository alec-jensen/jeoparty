---
import '@/styles/global.css';
import { PLAYER_COOKIE, verifyPlayerToken } from '@/lib/auth';
import { db, schema } from '@/lib/db';
import { eq } from 'drizzle-orm';

// Pre-fill game code from URL param: /join?code=ABCD
const code = (Astro.url.searchParams.get('code') ?? '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 4);

// Rejoin: check if the player has an active game cookie
let rejoinGameId: string | null = null;
let rejoinName: string | null = null;
try {
  const existing = Astro.cookies.get(PLAYER_COOKIE)?.value;
  if (existing) {
    const payload = verifyPlayerToken(existing);
    if (payload) {
      const rows = await db.select({ status: schema.games.status })
        .from(schema.games).where(eq(schema.games.id, payload.gameId));
      if (rows.length && rows[0].status !== 'finished') {
        const playerRows = await db.select({ displayName: schema.players.displayName })
          .from(schema.players).where(eq(schema.players.id, payload.playerId));
        if (playerRows.length) {
          rejoinGameId = payload.gameId;
          rejoinName = playerRows[0].displayName;
        }
      }
    }
  }
} catch {}
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Join Game — Jeoparty</title>
  <style>
    html, body { height: 100%; }
    body {
      background: var(--bg);
      background-image: radial-gradient(ellipse at 50% 0%, var(--bg3) 0%, var(--bg) 70%);
    }
    .join-shell {
      min-height: 100vh;
      max-width: 440px;
      margin: 0 auto;
      padding: 60px 28px 32px;
      display: flex;
      flex-direction: column;
    }
    .join-title {
      font-family: 'Anton', sans-serif;
      font-size: 56px;
      color: var(--gold);
      letter-spacing: 0.02em;
      line-height: 1;
      text-align: center;
    }
    .join-tagline {
      font-size: 12px;
      color: var(--dim);
      letter-spacing: 0.22em;
      text-align: center;
      margin-top: 6px;
    }
    .field-label {
      font-size: 11px;
      color: var(--dim);
      letter-spacing: 0.25em;
      font-weight: 600;
      text-transform: uppercase;
    }
    .code-row { display: flex; gap: 10px; margin-top: 12px; }
    .code-box {
      flex: 1;
      aspect-ratio: 0.85;
      background: var(--bg2);
      border: 2px solid var(--gold);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Anton', sans-serif;
      font-size: 56px;
      color: var(--ink);
      cursor: text;
      user-select: none;
    }
    .code-box.empty { color: var(--dim2); }
    .code-box.focused {
      box-shadow: 0 0 0 4px rgba(255,200,61,0.18);
    }
    /* Hidden input that captures all code keystrokes */
    .code-input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
      width: 1px;
      height: 1px;
    }
    .name-field {
      margin-top: 12px;
      background: var(--bg2);
      border: 2px solid var(--line);
      border-radius: 14px;
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: border-color 0.15s ease;
    }
    .name-field:focus-within { border-color: var(--gold); }
    .avatar-tile {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--magenta);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; line-height: 1; color: #0E0B22; font-weight: 800;
      cursor: pointer;
      flex-shrink: 0;
      transition: transform 0.12s ease;
      user-select: none; -webkit-user-select: none;
    }
    .avatar-tile:active { transform: scale(0.92); }
    .name-input {
      font-family: 'Anton', sans-serif;
      font-size: 26px;
      letter-spacing: 0.04em;
      color: var(--ink);
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      padding: 0;
      text-transform: uppercase;
    }
    .name-input::placeholder { color: var(--dim2); }
    .name-hint {
      font-size: 11px;
      color: var(--dim);
      margin-top: 8px;
      letter-spacing: 0.04em;
    }
    .join-btn {
      background: var(--gold);
      color: #0E0B22;
      font-family: 'Anton', sans-serif;
      font-size: 28px;
      letter-spacing: 0.08em;
      padding: 22px 0;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      width: 100%;
      box-shadow: 0 14px 0 #B88A1F, 0 22px 40px rgba(255,200,61,0.3);
      transition: transform 0.08s ease, box-shadow 0.08s ease;
    }
    .join-btn:active {
      transform: translateY(6px);
      box-shadow: 0 8px 0 #B88A1F, 0 12px 24px rgba(255,200,61,0.25);
    }
    .join-btn:disabled {
      opacity: 0.55; cursor: not-allowed; transform: none;
      box-shadow: 0 14px 0 #B88A1F, 0 22px 40px rgba(255,200,61,0.2);
    }
    .footer-link {
      margin-top: 18px;
      text-align: center;
      font-size: 13px;
      color: var(--dim);
      letter-spacing: 0.04em;
    }
    .footer-link a {
      color: var(--gold);
      text-decoration: underline;
      text-underline-offset: 3px;
      font-weight: 600;
    }
    .err-msg {
      text-align: center;
      min-height: 1.2em;
      font-size: 13px;
      color: var(--red);
      margin-top: 12px;
      letter-spacing: 0.02em;
    }
    .grow { flex: 1; min-height: 24px; }
    .hidden { display: none !important; }

    /* Rejoin banner */
    .rejoin-banner {
      background: var(--bg2);
      border: 1.5px solid var(--gold);
      border-radius: 16px;
      padding: 18px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .rejoin-info { flex: 1; min-width: 0; }
    .rejoin-eyebrow { font-size: 10px; color: var(--gold); letter-spacing: 0.24em; font-weight: 700; }
    .rejoin-name { font-family: 'Anton', sans-serif; font-size: 20px; color: var(--ink); letter-spacing: 0.04em; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .rejoin-btn {
      background: var(--gold); color: #0E0B22;
      font-family: 'Anton', sans-serif; font-size: 14px; letter-spacing: 0.1em;
      padding: 10px 16px; border-radius: 999px; border: none; cursor: pointer; white-space: nowrap;
    }
    .rejoin-btn:active { opacity: 0.85; }

    /* Host card variant */
    .host-card {
      margin-top: 36px;
      background: var(--bg2);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 24px 22px;
    }
    .host-card h2 {
      font-family: 'Anton', sans-serif;
      font-size: 26px;
      letter-spacing: 0.04em;
      text-align: center;
      color: var(--ink);
    }
    .host-card p {
      text-align: center;
      font-size: 13px;
      color: var(--dim);
      margin: 8px 0 18px;
    }
    .switch-btn {
      background: transparent;
      color: var(--ink);
      border: 1.5px solid var(--line);
      font-family: 'Anton', sans-serif;
      font-size: 14px;
      letter-spacing: 0.12em;
      padding: 12px 18px;
      border-radius: 999px;
      cursor: pointer;
      display: block;
      margin: 14px auto 0;
    }
    .switch-btn:hover { border-color: var(--line2); }
  </style>
</head>
<body>
  <main class="join-shell">
    <!-- 3D logo container — replaces plain text title -->
    <div id="logoContainer" style="position: relative; height: 120px; width: 100%; margin-bottom: -8px;" aria-hidden="true"></div>
    <div class="join-tagline">PARTY · TRIVIA · CHAOS</div>

    {rejoinGameId && (
      <div class="rejoin-banner" style="margin-top: 28px;">
        <div class="rejoin-info">
          <div class="rejoin-eyebrow">GAME IN PROGRESS · {rejoinGameId}</div>
          <div class="rejoin-name">{rejoinName}</div>
        </div>
        <a href={`/game/${rejoinGameId}/play`} class="rejoin-btn">REJOIN →</a>
      </div>
    )}

    <!-- Player join -->
    <section id="joinCard">
      <div style="margin-top: 56px;">
        <div class="field-label">ROOM CODE</div>
        <div class="code-row" id="codeRow">
          <div class="code-box empty" data-idx="0"></div>
          <div class="code-box empty" data-idx="1"></div>
          <div class="code-box empty" data-idx="2"></div>
          <div class="code-box empty" data-idx="3"></div>
        </div>
        <input
          id="gameCode"
          class="code-input"
          maxlength="4"
          autocomplete="off"
          autocapitalize="characters"
          inputmode="text"
          value={code}
        />
      </div>

      <div style="margin-top: 32px;">
        <div class="field-label">YOUR NAME</div>
        <div class="name-field">
          <span id="avatarTile" class="avatar-tile" title="Tap to change style">✦</span>
          <input
            id="displayName"
            class="name-input"
            maxlength="24"
            placeholder="YOUR NAME"
            autocomplete="nickname"
          />
        </div>
        <div class="name-hint">Tap your avatar to change style.</div>
      </div>

      <p id="joinMsg" class="err-msg"></p>

      <div class="grow"></div>

      <button id="joinBtn" class="join-btn">JOIN GAME →</button>
      <div class="footer-link">
        Hosting tonight? <a href="#" id="switchHostBtn">Join as host →</a>
      </div>
    </section>

    <!-- Host join -->
    <section id="hostCard" class="host-card hidden">
      <h2>JOIN AS HOST</h2>
      <p>Enter the game code, then verify it's your game.</p>

      <div class="field-label">ROOM CODE</div>
      <div class="code-row" id="hostCodeRow">
        <div class="code-box empty" data-idx="0"></div>
        <div class="code-box empty" data-idx="1"></div>
        <div class="code-box empty" data-idx="2"></div>
        <div class="code-box empty" data-idx="3"></div>
      </div>
      <input
        id="hostGameCode"
        class="code-input"
        maxlength="4"
        autocomplete="off"
        autocapitalize="characters"
        inputmode="text"
        value={code}
      />

      <p id="hostMsg" class="err-msg"></p>

      <button id="hostJoinBtn" class="join-btn" style="margin-top:18px; font-size:22px;">OPEN HOST CONTROLS →</button>
      <button id="switchPlayerBtn" class="switch-btn">← BACK TO PLAYER JOIN</button>
    </section>
  </main>

  <script is:inline>
    // @ts-nocheck

    /* ── Code box wiring ─────────────────────────────────────────────────── */
    function wireCodeInput(inputId, rowId) {
      const input = document.getElementById(inputId);
      const row = document.getElementById(rowId);
      const boxes = row.querySelectorAll('.code-box');

      function render() {
        const val = input.value.toUpperCase();
        boxes.forEach((box, i) => {
          const ch = val[i] || '';
          box.textContent = ch;
          box.classList.toggle('empty', !ch);
          box.classList.toggle('focused', i === val.length && document.activeElement === input);
        });
        // If full and last is focused, drop focused ring
        if (val.length === 4) boxes[3].classList.remove('focused');
      }

      input.addEventListener('input', () => {
        const pos = input.selectionStart;
        input.value = input.value.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 4);
        input.setSelectionRange(pos, pos);
        render();
      });
      input.addEventListener('focus', render);
      input.addEventListener('blur', render);
      row.addEventListener('click', () => { input.focus(); });

      render();
    }

    wireCodeInput('gameCode', 'codeRow');
    wireCodeInput('hostGameCode', 'hostCodeRow');

    /* ── Avatar picker (shared system: 6 colors × 3 shapes × 6 glyphs) ───── */
    const AV_COLORS = ['#FF3D8E','#FFC83D','#5EEBC1','#7C5CFF','#FF8A3D','#5BA9FF'];
    const _SQUIG = 'polygon(50.0% 2.0%,53.1% 2.8%,55.9% 4.9%,58.4% 7.8%,60.5% 10.9%,62.4% 13.4%,64.5% 14.9%,67.1% 15.3%,70.2% 14.9%,73.9% 14.2%,77.7% 13.9%,81.2% 14.4%,83.9% 16.1%,85.6% 18.8%,86.1% 22.3%,85.8% 26.1%,85.1% 29.7%,84.7% 32.9%,85.1% 35.5%,86.6% 37.6%,89.1% 39.5%,92.2% 41.6%,95.1% 44.1%,97.2% 46.9%,98.0% 50.0%,97.2% 53.1%,95.1% 55.9%,92.2% 58.4%,89.1% 60.5%,86.6% 62.4%,85.1% 64.5%,84.7% 67.1%,85.1% 70.2%,85.8% 73.9%,86.1% 77.7%,85.6% 81.2%,83.9% 83.9%,81.2% 85.6%,77.7% 86.1%,73.9% 85.8%,70.2% 85.1%,67.1% 84.7%,64.5% 85.1%,62.4% 86.6%,60.5% 89.1%,58.4% 92.2%,55.9% 95.1%,53.1% 97.2%,50.0% 98.0%,46.9% 97.2%,44.1% 95.1%,41.6% 92.2%,39.5% 89.1%,37.6% 86.6%,35.5% 85.1%,32.9% 84.7%,29.8% 85.1%,26.1% 85.8%,22.3% 86.1%,18.8% 85.6%,16.1% 83.9%,14.4% 81.2%,13.9% 77.7%,14.2% 73.9%,14.9% 70.3%,15.3% 67.1%,14.9% 64.5%,13.4% 62.4%,10.9% 60.5%,7.8% 58.4%,4.9% 55.9%,2.8% 53.1%,2.0% 50.0%,2.8% 46.9%,4.9% 44.1%,7.8% 41.6%,10.9% 39.5%,13.4% 37.6%,14.9% 35.5%,15.3% 32.9%,14.9% 29.7%,14.2% 26.1%,13.9% 22.3%,14.4% 18.8%,16.1% 16.1%,18.8% 14.4%,22.3% 13.9%,26.1% 14.2%,29.7% 14.9%,32.9% 15.3%,35.5% 14.9%,37.6% 13.4%,39.5% 10.9%,41.6% 7.8%,44.1% 4.9%,46.9% 2.8%)';
    const AV_OUTERS = [
      { r: '50%', cp: ''     },  // circle
      { r: '28%', cp: ''     },  // rounded square
      { r: '',    cp: _SQUIG },  // squiggly
    ];
    const AV_INNERS = ['✦','◆','●','▲','◐','■'];
    const NUM_C = 6, NUM_O = 3, NUM_I = 6, NUM_COMBOS = 108;

    function avFromDb(color, shape) {
      const c = (color ?? 0) % NUM_C;
      const s = shape ?? 0;
      const outer = AV_OUTERS[Math.floor(s / NUM_I) % NUM_O];
      return { bg: AV_COLORS[c], radius: outer.r, clipPath: outer.cp, glyph: AV_INNERS[s % NUM_I] };
    }
    function comboToDb(combo) {
      const total = NUM_O * NUM_I;
      return { avatarColor: Math.floor(combo / total) % NUM_C, avatarShape: combo % total };
    }

    const avatarTile = document.getElementById('avatarTile');
    let avatarIdx = 0;
    try {
      const saved = localStorage.getItem('jp.avatar');
      if (saved != null) avatarIdx = Math.max(0, Math.min(NUM_COMBOS - 1, parseInt(saved, 10) || 0));
    } catch {}

    function paintAvatar() {
      const { avatarColor, avatarShape } = comboToDb(avatarIdx);
      const av = avFromDb(avatarColor, avatarShape);
      avatarTile.style.background   = av.bg;
      avatarTile.style.borderRadius = av.radius;
      avatarTile.style.clipPath     = av.clipPath;
      avatarTile.textContent        = av.glyph;
    }
    paintAvatar();

    avatarTile.addEventListener('click', () => {
      // Cycle randomly through all combos (excluding current)
      const next = (avatarIdx + 1 + Math.floor(Math.random() * (NUM_COMBOS - 1))) % NUM_COMBOS;
      avatarIdx = next;
      paintAvatar();
      try { localStorage.setItem('jp.avatar', String(avatarIdx)); } catch {}
    });

    /* ── Switch cards ────────────────────────────────────────────────────── */
    const joinCard = document.getElementById('joinCard');
    const hostCard = document.getElementById('hostCard');
    document.getElementById('switchHostBtn').addEventListener('click', (e) => {
      e.preventDefault();
      joinCard.classList.add('hidden');
      hostCard.classList.remove('hidden');
      document.getElementById('hostGameCode').value = document.getElementById('gameCode').value;
      document.getElementById('hostGameCode').dispatchEvent(new Event('input'));
    });
    document.getElementById('switchPlayerBtn').addEventListener('click', () => {
      hostCard.classList.add('hidden');
      joinCard.classList.remove('hidden');
    });

    /* ── Player join submit ──────────────────────────────────────────────── */
    const joinMsg = document.getElementById('joinMsg');
    document.getElementById('joinBtn').addEventListener('click', async () => {
      joinMsg.textContent = '';
      const code = document.getElementById('gameCode').value.trim().toUpperCase();
      const name = document.getElementById('displayName').value.trim();
      if (code.length !== 4) { joinMsg.textContent = 'Enter a 4-character room code.'; return; }
      if (!name) { joinMsg.textContent = 'Enter your name.'; return; }

      try { localStorage.setItem('jp.displayName', name); } catch {}

      const res = await fetch(`/api/games/${code}/join`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ displayName: name, ...comboToDb(avatarIdx) }),
      });
      if (!res.ok) {
        const json = await res.json().catch(() => ({}));
        joinMsg.textContent = json.error || 'Could not join game.';
        return;
      }
      location.href = `/game/${code}/play`;
    });

    /* ── Host join submit ────────────────────────────────────────────────── */
    const hostMsg = document.getElementById('hostMsg');
    document.getElementById('hostJoinBtn').addEventListener('click', async () => {
      hostMsg.textContent = '';
      const code = document.getElementById('hostGameCode').value.trim().toUpperCase();
      if (code.length !== 4) { hostMsg.textContent = 'Enter a 4-character room code.'; return; }

      const res = await fetch(`/api/games/${code}/host-check`);
      if (res.status === 401) {
        location.href = `/?showLogin=1&next=${encodeURIComponent(`/game/${code}/host`)}`;
        return;
      }
      if (res.status === 403) { hostMsg.textContent = "This game belongs to a different account."; return; }
      if (!res.ok) { hostMsg.textContent = 'Game not found.'; return; }
      location.href = `/game/${code}/host`;
    });

    /* ── Pre-fill name from local storage ────────────────────────────────── */
    try {
      const savedName = localStorage.getItem('jp.displayName');
      if (savedName) document.getElementById('displayName').value = savedName;
    } catch {}
  </script>

  <!-- 3D logo (non-inline script so Vite can bundle Three.js) -->
  <script>
    import { createLogoIdle } from '@/scripts/intro-3d';
    const container = document.getElementById('logoContainer');
    if (container) {
      createLogoIdle(container, '/fonts/Anton.typeface.json').catch(() => {});
    }
  </script>
</body>
</html>
